def seed():
    db = SessionLocal()
    try:
        # 멱등: 기존 전부 삭제 후 재삽입
        db.query(BindVariable).delete()
        db.query(Plan).delete()
        db.query(TuningCase).delete()
        db.commit()

        all_cases = PRACTICE_CASES + MOCK_CASES
        for c in all_cases:
            plans = c.pop("plans", [])
            binds = c.pop("binds", [])
            case = TuningCase(**c)
            db.add(case)
            db.flush()
            for p in plans:
                db.add(Plan(case_id=case.id, **p))
            for i, b in enumerate(binds, start=1):
                b.setdefault("position", i)
                db.add(BindVariable(case_id=case.id, **b))
        db.commit()
        n_cases = db.query(TuningCase).count()
        n_plans = db.query(Plan).count()
        n_binds = db.query(BindVariable).count()
        print(f"seeded: cases={n_cases}, plans={n_plans}, binds={n_binds}")
    finally:
        db.close()


if __name__ == "__main__":
    seed()
