export async function fetchTuningRequestDetail(id: number | string): Promise<TuningRequestDetail> {
  const r = await fetch(`${BASE}/api/tuning/requests/${encodeURIComponent(String(id))}`)
  return jsonOrThrow<TuningRequestDetail>(r, 'fetchTuningRequestDetail')
}


export async function fetchTuningRequests(params: ListTuningRequestsParams = {}): Promise<TuningRequestSummary[]> {
  const qs = new URLSearchParams()
  const append = (k: string, v: unknown) => {
    if (v === undefined || v === null || v === '') return
    if (Array.isArray(v)) v.forEach(x => qs.append(k, String(x)))
    else qs.append(k, String(v))
  }
  append('status', params.status)
  append('source', params.source)
  append('schema_name', params.schema_name)
  append('instance_id', params.instance_id)
  append('from_date', params.from_date)
  append('to_date', params.to_date)
  append('limit', params.limit)
  append('offset', params.offset)
  const r = await fetch(`${BASE}/api/tuning/requests?${qs.toString()}`)
  return jsonOrThrow<TuningRequestSummary[]>(r, 'fetchTuningRequests')
}

// 튜닝 요청 일괄 삭제 (DB 에서 실제 삭제) — 선택된 id 배열과 descendant 를 함께 삭제
export interface BulkDeleteTuningResponse {
  deleted_request_ids: string[]
  deleted_sql_plans: number
  deleted_sql_performance: number
}

export async function deleteTuningRequests(ids: string[]): Promise<BulkDeleteTuningResponse> {
  const r = await fetch(`${BASE}/api/tuning/requests/delete`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids }),
  })
  return jsonOrThrow<BulkDeleteTuningResponse>(r, 'deleteTuningRequests')
}

