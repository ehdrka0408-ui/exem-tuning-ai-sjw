export interface TuningRequestDetail extends TuningRequestResponse {
  tobe_sql_id?: string | null
  source_sql_text?: string | null
  tuned_sql_text?: string | null
  rationale?: string | null
  llm_provider?: string | null
  llm_model?: string | null
  input_tokens?: number | null
  output_tokens?: number | null
  latency_ms?: number | null
  requested_at?: string | null
  completed_at?: string | null
  performance?: TuningRequestPerfRow[]
  plans?: TuningRequestPlanRow[]
  // Phase 2 호환: 단순 접근용 별칭 (필요 시 calling 측에서 채움)
  after_performance?: BeforePerformance | null
  after_plan?: string | null
  applied_performance?: BeforePerformance | null
  applied_plan?: string | null
  attempts?: number | null
  improvement_pct?: number | null
}

async function jsonOrThrow<T>(r: Response, label: string): Promise<T> {
  if (!r.ok) {
    const text = await r.text().catch(() => '')
    throw new Error(`${label} failed: ${r.status} ${text}`)
  }
  return r.json() as Promise<T>
}

