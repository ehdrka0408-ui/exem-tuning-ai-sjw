/* ─── Helpers ─── */
function formatNumber(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M'
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K'
  return n.toString()
}

function formatMs(sec: number): string {
  return sec.toFixed(2) + 's'
}

function applyFilters(list: Candidate[], filters: FilterToken[]): Candidate[] {
  return list.filter(c =>
    filters.every(f => {
      switch (f.property) {
        case 'sqlId': return c.sqlId.toLowerCase().includes(f.value.toLowerCase())
        case 'sqlText': return c.sqlText.toLowerCase().includes(f.value.toLowerCase())
        case 'module': return c.module.toLowerCase().includes(f.value.toLowerCase())
        default: return true
      }
    })
  )
}

/* ─── Mock Execution Plan Data ─── */
// Plan Hash별 실행계획 — sqlId → planHash → PlanRow[]
const MOCK_PLANS_BY_HASH: Record<string, Record<string, PlanRow[]>> = {}

// fallback: sqlId → 첫 번째 plan hash의 rows
function getMockPlans(sqlId: string, planHash?: string): PlanRow[] {
  const byHash = MOCK_PLANS_BY_HASH[sqlId]
  if (!byHash) return []
  if (planHash && byHash[planHash]) return byHash[planHash]
  const first = Object.values(byHash)[0]
  return first || []
}

function getMockPlanHashes(sqlId: string): string[] {
  const byHash = MOCK_PLANS_BY_HASH[sqlId]
  return byHash ? Object.keys(byHash) : []
}

const MOCK_BINDS: Record<string, BindVariable[]> = {}

/** Get metric value based on Total or Avg mode */
function getMetricValue(row: Candidate, key: SortKey, mode: ValueMode): number {
  const raw = row[key]
  if (mode === 'avg' && key !== 'executions') {
    return raw / Math.max(row.executions, 1)
  }
  return raw
}

/* ─── Property Filter (AWS Console style) ─── */
function PropertyFilter({
  filters,
  onFiltersChange,
}: {
  filters: FilterToken[]
  onFiltersChange: (filters: FilterToken[]) => void
}) {
  const [step, setStep] = useState<'idle' | 'selectProperty' | 'selectValue'>('idle')
  const [selectedProp, setSelectedProp] = useState<typeof FILTER_PROPERTIES[number] | null>(null)
  const [textValue, setTextValue] = useState('')
  const [searchText, setSearchText] = useState('')
  const inputRef = useRef<HTMLInputElement>(null)
  const containerRef = useRef<HTMLDivElement>(null)

  useEffect(() => {
    function handleClickOutside(e: MouseEvent) {
      if (containerRef.current && !containerRef.current.contains(e.target as Node)) {
        resetState()
      }
    }
    document.addEventListener('mousedown', handleClickOutside)
    return () => document.removeEventListener('mousedown', handleClickOutside)
  }, [])

  function resetState() {
    setStep('idle')
    setSelectedProp(null)
    setTextValue('')
    setSearchText('')
  }

  function handleInputFocus() {
    if (step === 'idle') {
      setStep('selectProperty')
      setSearchText('')
    }
  }

  function handleSelectProperty(prop: typeof FILTER_PROPERTIES[number]) {
    setSelectedProp(prop)
    setStep('selectValue')
    setSearchText('')
    setTextValue('')
    setTimeout(() => inputRef.current?.focus(), 0)
  }

  function handleSelectValue(value: string, label: string) {
    if (!selectedProp) return
    const token: FilterToken = {
      id: `${selectedProp.key}-${value}-${Date.now()}`,
      property: selectedProp.key,
      propertyLabel: selectedProp.label,
      operator: '=',
      value,
      valueLabel: label,
    }
    onFiltersChange([...filters, token])
    resetState()
  }

  function handleTextSubmit() {
    if (!selectedProp || !textValue.trim()) return
    handleSelectValue(textValue.trim(), textValue.trim())
  }

  function handleKeyDown(e: React.KeyboardEvent) {
    if (e.key === 'Enter' && step === 'selectValue' && selectedProp?.type === 'text') {
      handleTextSubmit()
    }
    if (e.key === 'Escape') resetState()
    if (e.key === 'Backspace' && searchText === '' && step === 'selectProperty' && filters.length > 0) {
      onFiltersChange(filters.slice(0, -1))
    }
  }

  function removeFilter(id: string) {
    onFiltersChange(filters.filter(f => f.id !== id))
  }

  const filteredProperties = FILTER_PROPERTIES.filter(p =>
    p.label.toLowerCase().includes(searchText.toLowerCase())
  )
  return (
    <div ref={containerRef} className="relative">
      <div
        className={`flex min-h-[30px] flex-wrap items-center gap-1.5 rounded-md border bg-white px-3 py-1.5 text-sm transition-colors ${
          step !== 'idle' ? 'border-action ring-1 ring-action' : 'border-border hover:border-text-muted'
        }`}
        onClick={() => inputRef.current?.focus()}
      >
        <Search className="h-3.5 w-3.5 shrink-0 text-text-muted" />
        {filters.map(f => (
          <span key={f.id} className="inline-flex items-center gap-1 rounded bg-surface-muted px-2 py-0.5 text-[11px] font-medium text-text-primary">
            <span className="text-text-muted">{f.propertyLabel}</span>
            <span className="text-border">{f.operator}</span>
            <span>{f.valueLabel}</span>
            <button onClick={e => { e.stopPropagation(); removeFilter(f.id) }} className="ml-0.5 rounded-full p-0.5 hover:bg-surface-alt">
              <X className="h-3 w-3" />
            </button>
          </span>
        ))}
        {step === 'selectValue' && selectedProp && (
          <span className="text-[11px] font-medium text-text-primary">
            {selectedProp.label} =
          </span>
        )}
        <input
          ref={inputRef}
          value={step === 'selectValue' && selectedProp?.type === 'text' ? textValue : searchText}
          onChange={e => {
            if (step === 'selectValue' && selectedProp?.type === 'text') setTextValue(e.target.value)
            else setSearchText(e.target.value)
          }}
          onFocus={handleInputFocus}
          onKeyDown={handleKeyDown}
          placeholder={
            filters.length === 0 && step === 'idle' ? '속성 또는 값으로 필터링...'
              : step === 'selectProperty' ? '속성 선택...'
              : step === 'selectValue' && selectedProp?.type === 'text' ? '값 입력 후 Enter...'
              : '값 선택...'
          }
          className="min-w-[120px] flex-1 border-none bg-transparent text-xs text-text-primary outline-none placeholder:text-text-muted"
        />
        {filters.length > 0 && (
          <button onClick={e => { e.stopPropagation(); onFiltersChange([]); resetState() }} className="shrink-0 text-[11px] text-text-muted hover:text-text-secondary">
            모두 지우기
          </button>
        )}
      </div>

      {step === 'selectProperty' && (
        <div className="absolute left-0 top-full z-30 mt-1 w-64 rounded-md border border-border bg-white py-1 shadow-lg">
          <div className="px-3 py-1.5 text-[11px] font-medium text-text-muted">속성 선택</div>
          {filteredProperties.map(prop => (
            <button key={prop.key} onClick={() => handleSelectProperty(prop)} className="flex w-full items-center justify-between px-3 py-2 text-left text-xs text-text-primary hover:bg-surface">
              <span>{prop.label}</span>
              <span className="text-[11px] text-text-muted">{prop.type === 'text' ? '텍스트' : `${prop.options.length}개 옵션`}</span>
            </button>
          ))}
          {filteredProperties.length === 0 && <div className="px-3 py-2 text-xs text-text-muted">일치하는 속성 없음</div>}
        </div>
      )}

    </div>
  )
}

/* ─── Top SQL Trend Chart ─── */
function TopSqlTrendChart({
  metric,
  onRangeSelect,
  highlightSqlId,
}: {
  metric: TrendMetric
  onMetricChange?: (m: TrendMetric) => void
  onRangeSelect: (start: Date, end: Date) => void
  highlightSqlId: string | null
}) {
  const data = useMemo(() => generateTopSqlTrend(metric), [metric])

  // Drag state (active dragging)
  const [dragLeft, setDragLeft] = useState<string>('')
  const [dragRight, setDragRight] = useState<string>('')
  const isDragging = useRef(false)

  // Persisted selection (stays after drag ends)
  const [selectedLeft, setSelectedLeft] = useState<string>('')
  const [selectedRight, setSelectedRight] = useState<string>('')

  // Custom tooltip state (replaces Recharts Tooltip entirely)
  const [hoverInfo, setHoverInfo] = useState<{ label: string; x: number; y: number } | null>(null)
  const chartWrapperRef = useRef<HTMLDivElement>(null)

  const metricUnit = METRIC_UNITS[metric]
  const formatVal = (v: number) => {
    if (v >= 1_000_000) return (v / 1_000_000).toFixed(1) + 'M'
    if (v >= 1_000) return (v / 1_000).toFixed(0) + 'K'
    return String(v)
  }

  const highlightLabel = highlightSqlId
    ? highlightSqlId.slice(0, 6) + '...'
    : null

  const handleMouseDown = (e: any) => {
    if (e?.activeLabel) {
      setDragLeft(e.activeLabel)
      setDragRight('')
      setSelectedLeft('')
      setSelectedRight('')
      isDragging.current = true
      setHoverInfo(null)
    }
  }

  const handleMouseMove = (e: any) => {
    if (isDragging.current && e?.activeLabel) {
      setDragRight(e.activeLabel)
    } else if (!isDragging.current && e?.activeLabel && e?.activeCoordinate) {
      setHoverInfo({ label: e.activeLabel, x: e.activeCoordinate.x, y: e.activeCoordinate.y })
    }
  }

  const handleMouseUp = () => {
    if (!isDragging.current) return
    isDragging.current = false

    if (dragLeft && dragRight && dragLeft !== dragRight) {
      setSelectedLeft(dragLeft)
      setSelectedRight(dragRight)

      const ptL = data.find(d => d.time === dragLeft)
      const ptR = data.find(d => d.time === dragRight)
      if (ptL && ptR) {
        const t1 = Math.min(ptL.timestamp, ptR.timestamp)
        const t2 = Math.max(ptL.timestamp, ptR.timestamp)
        onRangeSelect(new Date(t1), new Date(t2))
      }
    }
    setDragLeft('')
    setDragRight('')
  }

  const handleMouseLeave = () => {
    handleMouseUp()
    setHoverInfo(null)
  }

  const clearSelection = () => {
    setSelectedLeft('')
    setSelectedRight('')
  }

  // Which area to show: active drag takes priority, then persisted selection
  const showAreaLeft = isDragging.current && dragLeft ? dragLeft : selectedLeft
  const showAreaRight = isDragging.current && dragRight ? dragRight : selectedRight

  // Find the hovered data point for custom tooltip
  const hoveredPoint = hoverInfo ? data.find(d => d.time === hoverInfo.label) : null

  return (
    <div className="rounded-lg border border-border bg-white shadow-sm">
      {/* Header */}
      <div className="flex items-center justify-between border-b border-surface-muted px-4 py-1.5">
        <div className="flex items-center gap-3">
          <h3 className="text-xs font-semibold text-text-primary">전체 부하 트렌드 — {TREND_METRICS.find(m => m.value === metric)?.label}</h3>
          {highlightSqlId && (
            <span className="flex items-center gap-1.5 rounded-full bg-code-bg px-2.5 py-0.5 text-xs font-medium text-code">
              <span className="inline-block h-1.5 w-1.5 rounded-full bg-code" />
              {highlightLabel} 선택됨
            </span>
          )}
          {selectedLeft && selectedRight && (
            <button
              onClick={clearSelection}
              className="flex items-center gap-1 rounded-full bg-surface-muted px-2.5 py-0.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors"
            >
              <X size={12} />
              선택 해제
            </button>
          )}
        </div>
      </div>

      {/* Chart */}
      <div className="px-3 py-1.5">
        {/* Legend */}
        <div className="mb-1 flex items-center gap-4 text-[11px] text-text-secondary">
          <span className="flex items-center gap-1.5">
            <span className="inline-block h-2 w-6 rounded-sm bg-border/60" />
            전체 부하
          </span>
          {highlightSqlId && (
            <span className="flex items-center gap-1.5">
              <span className="inline-block h-2 w-6 rounded-sm bg-code/60" />
              선택 SQL ({highlightLabel})
            </span>
          )}
          <span className="ml-auto text-text-muted">
            차트를 드래그하여 시간 범위를 선택할 수 있습니다
          </span>
        </div>

        <div ref={chartWrapperRef} className="relative select-none no-recharts-tooltip">
        <ResponsiveContainer width="100%" height={140}>
          <AreaChart
            data={data}
            onMouseDown={handleMouseDown}
            onMouseMove={handleMouseMove}
            onMouseUp={handleMouseUp}
            onMouseLeave={handleMouseLeave}
            style={{ cursor: 'crosshair' }}
          >
            <CartesianGrid strokeDasharray="3 3" stroke="#f3f4f6" />
            <XAxis
              dataKey="time"
              tick={{ fontSize: 10, fill: '#9ca3af' }}
              axisLine={{ stroke: '#e5e7eb' }}
              tickLine={false}
              interval={11}
            />
            <YAxis
              tick={{ fontSize: 10, fill: '#9ca3af' }}
              axisLine={false}
              tickLine={false}
              tickFormatter={formatVal}
              width={50}
            />
            {/* No Recharts <Tooltip> — custom tooltip rendered outside */}
            {/* Total area — gray */}
            <Area
              type="monotone"
              dataKey="total"
              stroke={highlightSqlId ? '#d1d5db' : '#6b7280'}
              fill={highlightSqlId ? '#e5e7eb' : '#d1d5db'}
              fillOpacity={highlightSqlId ? 0.3 : 0.4}
              strokeWidth={highlightSqlId ? 1 : 1.5}
              activeDot={false}
              isAnimationActive={false}
            />
            {/* Highlighted SQL overlay — indigo */}
            {highlightSqlId && (
              <Area
                type="monotone"
                dataKey={highlightSqlId}
                stroke="#4f46e5"
                fill="#4f46e5"
                fillOpacity={0.25}
                strokeWidth={2}
                activeDot={false}
                isAnimationActive={false}
              />
            )}
            {/* Drag selection area */}
            {showAreaLeft && showAreaRight && (
              <ReferenceArea
                x1={showAreaLeft}
                x2={showAreaRight}
                stroke="#6366f1"
                strokeOpacity={0.4}
                fill="#818cf8"
                fillOpacity={0.15}
              />
            )}
          </AreaChart>
        </ResponsiveContainer>

        {/* Custom tooltip — rendered as absolute div outside Recharts */}
        {hoveredPoint && hoverInfo && !isDragging.current && (
          <div
            className="pointer-events-none absolute z-10 rounded-lg border border-border bg-white px-3 py-2 text-[13px] shadow-md"
            style={{ left: hoverInfo.x + 15, top: 10 }}
          >
            <div className="mb-1 font-medium text-text-primary">{hoverInfo.label}</div>
            <div className="text-text-secondary">
              전체 부하: {formatVal(hoveredPoint.total)} {metricUnit}
            </div>
            {highlightSqlId && hoveredPoint[highlightSqlId] != null && (
              <div className="text-code">
                SQL {highlightSqlId.slice(0, 6)}...: {formatVal(Number(hoveredPoint[highlightSqlId]))} {metricUnit}
                {' '}({((Number(hoveredPoint[highlightSqlId]) / (hoveredPoint.total || 1)) * 100).toFixed(1)}%)
              </div>
            )}
          </div>
        )}
        </div>
      </div>
    </div>
  )
}

