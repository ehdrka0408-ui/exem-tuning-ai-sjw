}

/* ─── Main Component ─── */
export default function TopSql() {
  const { colTerm: __ctxColTerm } = useObjectInfo()
  const navigate = useNavigate()
  const { addScheduledRequest, openPanel, setActiveTab: setQueueTab } = useQueue()
  const mgConnected = useMaxGaugeStatus()


  // ── Oracle API에서 실시간 Top SQL + 인스턴스 로드 ──
  const [apiCandidates, setApiCandidates] = useState<Candidate[]>([])
  const [oracleInstances, setOracleInstances] = useState<string[]>([])
  const [oracleInstanceList, setOracleInstanceList] = useState<{ id: string; name: string }[]>([])
  const [oracleSchemas, setOracleSchemas] = useState<string[]>([])
  const [apiLoading, setApiLoading] = useState(false)

  useEffect(() => {
    // 인스턴스 목록 로드
    fetch(`${API_BASE}/api/oracle/instances`)
      .then(r => r.json())
      .then((list: { id: string; name: string; schema: string }[]) => {
        setOracleInstances(list.map(i => i.name))
        setOracleInstanceList(list.map(i => ({ id: i.id, name: i.name })))
        setOracleSchemas([...new Set(list.map(i => i.schema).filter(Boolean))])
      })
      .catch(() => {})
  }, [])

  const fetchTopSql = useCallback((source: string, beginTime?: Date, endTime?: Date, sk?: string, vm?: string) => {
    setApiLoading(true)
    const params = new URLSearchParams({ source, top_n: '100', sort_key: sk || 'elapsed', value_mode: vm || 'total' })
    if (source === 'awr' && beginTime && endTime) {
      const pad = (n: number) => String(n).padStart(2, '0')
      const fmt = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`
      params.set('begin_time', fmt(beginTime))
      params.set('end_time', fmt(endTime))
    }
    fetch(`${API_BASE}/api/top-sql?${params}`)
      .then(r => r.json())
      .then((data: any[]) => {
        const mapped: Candidate[] = data.map((d, i) => ({
          sqlId: d.sqlId,
          sqlText: d.sqlText,
          elapsed: d.elapsed ?? 0,
          cpuTime: d.cpuTime ?? 0,
          logicalReads: d.logicalReads ?? 0,
          physicalReads: d.physicalReads ?? 0,
          buffers: d.logicalReads ?? 0,
          executions: d.executions ?? 0,
          impact: Math.max(0, 100 - i * 3),
          source: d.source as 'awr' | 'v$sql',
          module: d.module || 'UNKNOWN',
          instanceName: d.instanceName || 'UNKNOWN',
          schemaName: d.schemaName || 'UNKNOWN',
          planHashValue: String(1000000 + i),
          firstSeen: new Date(Date.now() - 86400000 * 7).toISOString().slice(0, 19).replace('T', ' '),
          lastSeen: new Date().toISOString().slice(0, 19).replace('T', ' '),
        }))
        setApiCandidates(mapped)
      })
      .catch(() => setApiCandidates([]))
      .finally(() => setApiLoading(false))
  }, [])

  // 소스 탭
  const [activeTab, setActiveTab] = useState<SourceTab>('v$sql')


  // 탭 전환 시 자동조회 안 함 — 조회 버튼 클릭 시에만 fetchTopSql 호출

  // candidates: maxgauge는 mock, awr/v$sql은 API
  const candidates = useMemo(() => {
    if (activeTab === 'maxgauge') return mockCandidates
    return apiCandidates
  }, [activeTab, apiCandidates])


  // 조회조건 — 시간 범위 (MaxGauge)
  const [startTime, setStartTime] = useState(() => new Date('2026-03-24T00:00:00'))
  const [endTime, setEndTime] = useState(() => new Date('2026-03-24T23:59:59'))

  const [instances, setInstances] = useState<string[]>([])
  const [schemas, setSchemas] = useState<string[]>([])
  const [modules, setModules] = useState<string[]>([])

  // 성능기준 popover
  const [perfCriteria, setPerfCriteria] = useState<PerfCriteria>(PERF_EMPTY)
  const [perfOpen, setPerfOpen] = useState(false)
  const perfRef = useRef<HTMLDivElement>(null)

  // 업무시간 (독립 필터)
  const [bizStart, setBizStart] = useState('09:00')
  const [bizEnd, setBizEnd] = useState('18:00')
  const [bizOpen, setBizOpen] = useState(false)
  const bizRef = useRef<HTMLDivElement>(null)

  // 조회조건 커밋 스냅샷 — 조회 버튼 클릭 시 갱신. 현재 값과 스냅샷이 다르면 dirty 표시.
  const [appliedQuery, setAppliedQuery] = useState<{
    startTime: Date; endTime: Date; instance: string; schemas: string[]; modules: string[]
    bizStart: string; bizEnd: string; perfCriteria: PerfCriteria
  }>(() => ({
    startTime: new Date('2026-03-24T00:00:00'),
    endTime: new Date('2026-03-24T23:59:59'),
    instance: '',
    schemas: [],
    modules: [],
    bizStart: '09:00',
    bizEnd: '18:00',
    perfCriteria: PERF_EMPTY,
  }))
  const handleQuery = useCallback(() => {
    setAppliedQuery({
      startTime,
      endTime,
      instance: instances[0] ?? '',
      schemas: [...schemas],
      modules: [...modules],
      bizStart,
      bizEnd,
      perfCriteria,
    })
    // 조회 버튼 클릭 시 API 재조회
    if (activeTab === 'awr') {
      fetchTopSql('awr', startTime, endTime, sortKey, valueMode)
    } else if (activeTab === 'v$sql') {
      fetchTopSql('v$sql', undefined, undefined, sortKey, valueMode)
    }
  }, [startTime, endTime, instances, schemas, modules, bizStart, bizEnd, perfCriteria, activeTab, fetchTopSql])

  // 트렌드 차트 메트릭
  const [trendMetric, setTrendMetric] = useState<TrendMetric>('elapsed')

  // 정렬/뷰/값 모드
  const [sortKey, setSortKey] = useState<SortKey>('elapsed')
  const [valueMode, setValueMode] = useState<ValueMode>('total')
  const [viewMode, setViewMode] = useState<ViewMode>('list')

  // 필터
  const [filters, setFilters] = useState<FilterToken[]>([])

  // SQL 선택/호버 상태
  const [selectedSql, setSelectedSql] = useState<Candidate | null>(null)
  const [hoveredSqlId, setHoveredSqlId] = useState<string | null>(null)
  const [confirmTarget, setConfirmTarget] = useState<Candidate | null>(null)
  const [toast, setToast] = useState<{ message: string; kind: 'created' | 'scheduled' | 'excepted' } | null>(null)

  // 예외 등록 모달
  const [exceptionTarget, setExceptionTarget] = useState<Candidate | null>(null)
  const [exceptionReason, setExceptionReason] = useState('')
  // 예외 스토어 변경 시 리렌더 트리거
  const [exceptionTick, setExceptionTick] = useState(0)
  useEffect(() => subscribeSqlExceptions(() => setExceptionTick(t => t + 1)), [])
  useEffect(() => {
    function handleClick(e: MouseEvent) {
      if (perfRef.current && !perfRef.current.contains(e.target as Node)) setPerfOpen(false)
      if (bizRef.current && !bizRef.current.contains(e.target as Node)) setBizOpen(false)
    }
    document.addEventListener('mousedown', handleClick)
    return () => document.removeEventListener('mousedown', handleClick)
  }, [])
  // 작업함 변화(신규 생성) 시 리렌더 트리거 — 방금 생성한 항목을 목록에서 제외하기 위함
  const [workVersion, setWorkVersion] = useState(0)

  // alias inline 편집 상태 (sqlId -> alias)
  const [aliasMap, setAliasMap] = useState<Record<string, string>>({})
  const handleAliasChange = (sqlId: string, value: string) => {
    setAliasMap(prev => ({ ...prev, [sqlId]: value }))
  }

  // Detail panel initial tab
  const [detailInitialTab, setDetailInitialTab] = useState<DetailInitialTab>('summary')

  // 상세 보기 방식: slide(기본) 또는 popup (한번 팝업으로 분리하면 세션 내 유지)
  const [detailMode, setDetailMode] = useState<'slide' | 'popup'>('slide')

  // 팝업 (여러 개)
  const [popups, setPopups] = useState<Candidate[]>([])
  const [focusedPopupId, setFocusedPopupId] = useState<string | null>(null)

  // SQL 선택 — detailMode에 따라 슬라이드 또는 팝업으로 열기
  const handleSelectSql = useCallback((sql: Candidate, initialTab: DetailInitialTab = 'summary') => {
    setDetailInitialTab(initialTab)
    if (detailMode === 'popup') {
      // 이미 팝업에 있으면 포커스만
      if (popups.some(p => p.sqlId === sql.sqlId)) {
        setFocusedPopupId(sql.sqlId)
        return
      }
      setPopups(prev => [...prev, sql])
      setFocusedPopupId(sql.sqlId)
    } else {
      setSelectedSql(sql)
    }
  }, [detailMode, popups])

  const handleClosePopup = useCallback((id: string) => {
    setPopups(prev => {
      const next = prev.filter(p => p.sqlId !== id)
      // 팝업이 모두 닫히면 슬라이드 모드로 복원
      if (next.length === 0) setDetailMode('slide')
      return next
    })
  }, [])

  const handleFocusPopup = useCallback((id: string) => {
    setFocusedPopupId(id)
  }, [])

  // 탭 전환 시 선택 SQL 초기화
  useEffect(() => {
    if (selectedSql && selectedSql.source !== activeTab) {
      setSelectedSql(null)
    }
    setHoveredSqlId(null)
  }, [activeTab])

  // 트렌드 차트에 하이라이트할 SQL: 호버 > 선택 > null
  const highlightSqlId = hoveredSqlId || selectedSql?.sqlId || null

  const handleTimeChange = useCallback((start: Date, end: Date) => {
    setStartTime(start)
    setEndTime(end)
  }, [])

  // 트렌드 차트 드래그 → 조회조건 시간 범위 변경
  const handleTrendRangeSelect = useCallback((start: Date, end: Date) => {
    setStartTime(start)
    setEndTime(end)
  }, [])

  // 소스별 카운트 (필터 전)
  const sourceCounts = useMemo(() => ({
    maxgauge: mockCandidates.filter(c => c.source === 'maxgauge').length,
    awr: apiCandidates.filter(c => c.source === 'awr').length,
    'v$sql': apiCandidates.filter(c => c.source === 'v$sql').length,
  }), [apiCandidates])

  // 현재 인스턴스의 AWR 스냅샷 목록
  const instanceSnapshots = useMemo(
    () => instances.length === 0 ? mockAwrSnapshots : mockAwrSnapshots.filter(s => instances.includes(s.instanceName)),
    [instances, mockAwrSnapshots],
  )

  // AWR: 시간 범위에 매핑되는 스냅샷 범위 계산
  const matchedSnaps = useMemo(() => {
    if (instanceSnapshots.length === 0) return null
    const startMs = startTime.getTime()
    const endMs = endTime.getTime()
    const toMs = (s: string) => new Date(s.replace(' ', 'T') + ':00').getTime()
    const first = instanceSnapshots.find(s => toMs(s.beginTime) >= startMs) ?? instanceSnapshots[0]
    const last = [...instanceSnapshots].reverse().find(s => toMs(s.endTime) <= endMs) ?? instanceSnapshots[instanceSnapshots.length - 1]
    return first.snapId <= last.snapId ? { begin: first.snapId, end: last.snapId } : null
  }, [instanceSnapshots, startTime, endTime])

  // 조회조건 → 소스필터 → 필터 → 정렬 → 예외 제외 → 중복 제외
  const filtered = useMemo(() => {
    let list = candidates.filter(c => c.source === activeTab)
    if (instances.length > 0) list = list.filter(c => instances.includes(c.instanceName))
    if (schemas.length > 0) list = list.filter(c => schemas.includes(c.schemaName))
    if (modules.length > 0) list = list.filter(c => modules.includes(c.module))
    list = applyFilters(list, filters)
    // 예외 등록된 SQL 제외
    list = list.filter(c => !isSqlException(c.sqlId))
    // 이미 활성 작업이 존재하는 SQL 제외 (중복 방지)
    list = list.filter(c => !isActiveWorkItem(c.sqlId))
    list.sort((a, b) => getMetricValue(b, sortKey, valueMode) - getMetricValue(a, sortKey, valueMode))
    return list
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [candidates, activeTab, sortKey, valueMode, instances, schemas, modules, filters, exceptionTick, workVersion])

  // 예외로 제외된 건수 (현재 소스 탭 기준)
  const excludedCount = useMemo(() => {
    let list = candidates.filter(c => c.source === activeTab)
    if (instances.length > 0) list = list.filter(c => instances.includes(c.instanceName))
    if (schemas.length > 0) list = list.filter(c => schemas.includes(c.schemaName))
    if (modules.length > 0) list = list.filter(c => modules.includes(c.module))
    list = applyFilters(list, filters)
    return list.filter(c => isSqlException(c.sqlId)).length
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [activeTab, instances, schemas, modules, filters, exceptionTick])

  // 중복 활성 작업으로 제외된 건수 (예외 제외 후 남은 후보 기준)
  const duplicateExcludedCount = useMemo(() => {
    let list = candidates.filter(c => c.source === activeTab)
    if (instances.length > 0) list = list.filter(c => instances.includes(c.instanceName))
    if (schemas.length > 0) list = list.filter(c => schemas.includes(c.schemaName))
    if (modules.length > 0) list = list.filter(c => modules.includes(c.module))
    list = applyFilters(list, filters)
    list = list.filter(c => !isSqlException(c.sqlId))
    return list.filter(c => isActiveWorkItem(c.sqlId)).length
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [activeTab, instances, schemas, modules, filters, exceptionTick, workVersion])

  const handleCreateWork = (c: Candidate) => { setConfirmTarget(c) }

  // ── 일괄 튜닝요청 선택 ──
  const [selectedIds, setSelectedIds] = useState<Set<string>>(new Set())
  const toggleSelected = useCallback((id: string) => {
    setSelectedIds(prev => {
      const next = new Set(prev)
      if (next.has(id)) next.delete(id)
      else next.add(id)
      return next
    })
  }, [])
  const [bulkConfirmOpen, setBulkConfirmOpen] = useState(false)
  const handleBulkRequest = () => {
    if (selectedIds.size === 0) return
    setBulkConfirmOpen(true)
  }
  const handleConfirmBulk = (opts: { scheduledAt?: string; queryTimeoutSec?: number }) => {
    const targets = filtered.filter(c => selectedIds.has(c.sqlId))
    if (targets.length === 0) { setBulkConfirmOpen(false); return }
    const count = targets.length

    if (opts.scheduledAt) {
      // 예약: workItems 에 넣지 않고 oneTime 예약 목록에만 추가
      const primary = targets[0]
      const instanceType = primary.instanceName.toLowerCase().includes('dev') ? 'dev' : 'production'
      addScheduledRequest({
        label: `Top SQL ${count}건 튜닝 요청`,
        instance: primary.instanceName,
        instanceType,
        sqlCount: count,
        scheduledAt: opts.scheduledAt,
      })
      setSelectedIds(new Set())
      setBulkConfirmOpen(false)
      setToast({ message: `${count}건 예약이 접수되었습니다.`, kind: 'scheduled' })
      setTimeout(() => setToast(null), 4000)
      return
    }

    // 즉시: 백엔드에 각 SQL 에 대해 실제 튜닝 요청 등록 (병렬)
    setSelectedIds(new Set())
    setBulkConfirmOpen(false)
    setToast({ message: `${count}건 튜닝 요청 전송 중...`, kind: 'created' })
    Promise.allSettled(targets.map(async c => {
      const resolved = oracleInstanceList.find(i => i.name === c.instanceName)
      const instanceId = resolved?.id || c.instanceName
      const fullSql = await fetchSqlFulltext(c.sqlId, c.sqlText)
      return requestTuning({
        sql_text: fullSql,
        schema_name: c.schemaName || undefined,
        instance_id: instanceId,
        binds: [],
        source: 'ui',
        auto_tune: true,
        requested_by: c.source === 'awr' ? 'AWR' : c.source === 'v$sql' ? 'V$SQL' : 'Top SQL',
      })
    }))
      .then(results => {
        const ok = results.filter(r => r.status === 'fulfilled').length
        const fail = results.length - ok
        setToast({
          message: fail === 0
            ? `${ok}건 튜닝 요청 접수됨 — 튜닝현황으로 이동합니다`
            : `${ok}건 접수 / ${fail}건 실패 — 튜닝현황으로 이동합니다`,
          kind: fail === 0 ? 'created' : 'excepted',
        })
        setTimeout(() => { setToast(null); navigate('/work') }, 1500)
      })
  }
  // 필터/탭 전환 시 선택 초기화
  useEffect(() => { setSelectedIds(new Set()) }, [activeTab, instances, schemas, modules, filters])

  const handleRegisterException = (c: Candidate) => {
    setExceptionReason('')
    setExceptionTarget(c)
  }

  const handleConfirmException = () => {
    if (!exceptionTarget) return
    addSqlException({
      sqlId: exceptionTarget.sqlId,
      sqlText: exceptionTarget.sqlText,
      reason: exceptionReason.trim() || undefined,
    })
    setExceptionTarget(null)
    setSelectedSql(null)
    setToast({ message: `예외 등록됨 (${exceptionTarget.sqlId}) — 이후 튜닝 대상에서 제외`, kind: 'excepted' })
    setTimeout(() => setToast(null), 4000)
  }

  const lastCreatedIdRef = useRef<string | null>(null)
  const handleConfirm = (opts: { scheduledAt?: string; queryTimeoutSec?: number }) => {
    if (!confirmTarget) return
    const sqlId = confirmTarget.sqlId

    if (opts.scheduledAt) {
      // 예약: workItems 에 넣지 않고 oneTime 예약 목록에만 추가
      const instanceType = confirmTarget.instanceName.toLowerCase().includes('dev') ? 'dev' : 'production'
      addScheduledRequest({
        label: `${sqlId} 튜닝 요청`,
        instance: confirmTarget.instanceName,
        instanceType,
        sqlCount: 1,
        scheduledAt: opts.scheduledAt,
      })
      setConfirmTarget(null)
      setSelectedSql(null)
      setToast({ message: `예약이 접수되었습니다 (${sqlId})`, kind: 'scheduled' })
      setTimeout(() => setToast(null), 4000)
      return
    }

    // 즉시: 백엔드에 실제 튜닝 요청 등록 (before 캡처 + LLM 파이프라인 트리거)
    const resolvedInstance = oracleInstanceList.find(i => i.name === confirmTarget.instanceName)
    const instanceId = resolvedInstance?.id || confirmTarget.instanceName
    const capturedTarget = confirmTarget
    setConfirmTarget(null)
    setSelectedSql(null)
    setToast({ message: `튜닝 요청 전송 중 (${sqlId})...`, kind: 'created' })
    fetchSqlFulltext(capturedTarget.sqlId, capturedTarget.sqlText).then(fullSql => requestTuning({
      sql_text: fullSql,
      schema_name: capturedTarget.schemaName || undefined,
      instance_id: instanceId,
      binds: [],
      source: 'ui',
      auto_tune: true,
      requested_by: capturedTarget.source === 'awr' ? 'AWR' : capturedTarget.source === 'v$sql' ? 'V$SQL' : 'Top SQL',
    }))
      .then(resp => {
        lastCreatedIdRef.current = `BE-${resp.request_id}`
        setWorkVersion(v => v + 1)
        setToast({ message: `튜닝 요청 접수됨 (#${resp.request_id}) — 튜닝현황으로 이동합니다`, kind: 'created' })
        setTimeout(() => { setToast(null); navigate('/work') }, 1200)
      })
      .catch(err => {
        console.error('[requestTuning failed]', err)
        setToast({ message: `튜닝 요청 실패: ${err instanceof Error ? err.message : String(err)}`, kind: 'excepted' })
        setTimeout(() => setToast(null), 6000)
      })
  }

  // ── isDirty & queryBtn ──
  const perfHasValues = Object.values(perfCriteria).some(v => v.total || v.avg)
  const arrayEq = (a: string[], b: string[]) => a.length === b.length && a.every((v, i) => v === b[i])
  const isDirty =
    startTime.getTime() !== appliedQuery.startTime.getTime() ||
    endTime.getTime() !== appliedQuery.endTime.getTime() ||
    (instances[0] ?? '') !== appliedQuery.instance ||
    !arrayEq(schemas, appliedQuery.schemas) ||
    !arrayEq(modules, appliedQuery.modules) ||
    bizStart !== appliedQuery.bizStart ||
    bizEnd !== appliedQuery.bizEnd ||
    JSON.stringify(perfCriteria) !== JSON.stringify(appliedQuery.perfCriteria)

  const queryBtn = (
