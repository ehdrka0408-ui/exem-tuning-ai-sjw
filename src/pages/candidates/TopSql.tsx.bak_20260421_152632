        >
          <div className="flex justify-end mb-2"><CopyButton text={bindToText()} /></div>
          {bindRows.length > 0 ? (
            <pre className="whitespace-pre-wrap font-mono text-[13px] leading-[1.6]">
              {highlightSQL(`-- Captured: ${bindRows[0].capturedAt}\n` + bindRows.map(b => `${b.name}\t${b.type}\t${b.value}`, __ctxColTerm).join('\n'))}
            </pre>
          ) : (
            <div className="text-xs text-text-muted text-center py-4">바인드 변수 데이터가 없습니다.</div>
