/* ─── Card View ─── */
function CardView({ items, onSelect, onCreateWork, onRegisterException, onHover, valueMode, sortKey, aliasMap, onAliasChange }: { items: Candidate[]; onSelect: (c: Candidate, initialTab?: DetailInitialTab) => void; onCreateWork: (c: Candidate) => void; onRegisterException: (c: Candidate) => void; onHover: (id: string | null) => void; valueMode: ValueMode; sortKey: SortKey; aliasMap: Record<string, string>; onAliasChange: (sqlId: string, value: string) => void }) {
  const isAvg = valueMode === 'avg'
  const div = (v: number, c: Candidate) => isAvg ? v / Math.max(c.executions, 1) : v

  // Sort metric helpers
  const sortLabel: Record<SortKey, string> = { elapsed: 'Elapsed', cpuTime: 'CPU', logicalReads: 'Logical Reads', physicalReads: 'Physical Reads', executions: 'Executions' }
  const sortTextColor: Record<SortKey, string> = { elapsed: 'text-code', cpuTime: 'text-code', logicalReads: 'text-code', physicalReads: 'text-code', executions: 'text-code' }
  const getSortVal = (c: Candidate) => {
    if (sortKey === 'executions') return c.executions
    return div(c[sortKey], c)
  }
  const formatSortVal = (c: Candidate) => {
    const v = getSortVal(c)
    if (sortKey === 'elapsed' || sortKey === 'cpuTime') return formatMs(v)
    return formatNumber(Math.round(v))
  }
  const sumSort = items.reduce((s, c) => s + getSortVal(c), 0)

  // Secondary metrics (all except sortKey)
  const secondaryKeys: { key: SortKey; label: string }[] = [
    { key: 'elapsed', label: 'Elapsed' },
    { key: 'cpuTime', label: 'CPU' },
    { key: 'logicalReads', label: 'LReads' },
    { key: 'physicalReads', label: 'PReads' },
    { key: 'executions', label: 'Execs' },
  ].filter(m => m.key !== sortKey) as { key: SortKey; label: string }[]

  const fmtSecondary = (c: Candidate, key: SortKey) => {
    if (key === 'executions') return formatNumber(c.executions)
    const v = div(c[key], c)
    if (key === 'elapsed' || key === 'cpuTime') return formatMs(v)
    return formatNumber(Math.round(v))
  }

  return (
    <div className="grid grid-cols-2 gap-2.5 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5">
      {items.map(c => {
        const sortVal = getSortVal(c)
        const sharePct = sumSort > 0 ? ((sortVal / sumSort) * 100).toFixed(0) : '0'
        return (
          <div key={c.sqlId} onClick={() => onSelect(c, 'summary')} onMouseEnter={() => onHover(c.sqlId)} onMouseLeave={() => onHover(null)} className="group relative cursor-pointer rounded-md border border-border bg-white shadow-sm transition-all hover:border-code/40 hover:shadow-md overflow-hidden">
            {/* 1. Identity + SQL Text */}
            <div className="px-3 pt-2.5 pb-1.5">
              <div className="flex items-center justify-between mb-1">
                <div className="flex items-center gap-1.5 min-w-0">
                  <span className="font-mono text-xs font-semibold text-text-primary truncate">{c.sqlId}</span>
                  <input
                    type="text"
                    defaultValue={aliasMap[c.sqlId] ?? c.alias ?? ''}
                    onBlur={e => { onAliasChange(c.sqlId, e.target.value) }}
                    onKeyDown={e => { if (e.key === 'Enter') (e.target as HTMLInputElement).blur() }}
                    onClick={e => e.stopPropagation()}
                    className="bg-transparent border-0 border-b border-transparent hover:border-border focus:border-action focus:outline-none text-[11px] text-text-muted px-0 py-0 truncate w-full"
                  />
                  <SourceBadge source={c.source} />
                  {findTerminalWorkItem(c.sqlId) && (
                    <span className="shrink-0 rounded px-1 py-0.5 text-[10px] font-medium bg-surface-muted text-text-secondary border border-border whitespace-nowrap">
                      기존 결과 있음
                    </span>
                  )}
                </div>
                <div className="flex items-center gap-0.5 shrink-0">
                  <button onClick={e => { e.stopPropagation(); onRegisterException(c) }} className="rounded p-0.5 text-text-muted transition-all hover:bg-danger-light hover:text-danger" title="예외 등록">
                    <Ban className="h-3.5 w-3.5" />
                  </button>
                  <button onClick={e => { e.stopPropagation(); onCreateWork(c) }} className="rounded p-0.5 text-text-muted transition-all hover:bg-code-bg hover:text-code" title="튜닝작업 생성">
                    <Plus className="h-3.5 w-3.5" />
                  </button>
                </div>
              </div>
              <div className="flex items-center gap-1.5 mb-1.5 text-[11px] text-text-muted">
                <span>{c.schemaName}</span>
                {c.module && <><span className="text-surface-muted">·</span><span>{c.module}</span></>}
              </div>
              <button
                onClick={e => { e.stopPropagation(); onSelect(c, 'sql') }}
                className="block w-full font-mono text-xs leading-tight text-code hover:text-code-dark hover:underline text-left line-clamp-2"
              >
                {c.sqlText.slice(0, 150)}
              </button>
            </div>

            {/* 2. Hero metric */}
            <div className="mx-3 my-1.5 flex items-center justify-between rounded bg-surface-alt px-2.5 py-1.5">
              <span className="text-xs text-text-secondary">{sortLabel[sortKey]} <span className="font-semibold text-text-primary">{formatSortVal(c)}</span></span>
              <span className="text-xs text-text-muted">전체 대비 <span className={`text-sm font-bold ${sortTextColor[sortKey]}`}>{sharePct}%</span></span>
            </div>

            {/* 3. Secondary metrics — 2×2 fixed grid */}
            <div className="grid grid-cols-2 gap-x-3 gap-y-0.5 px-3 pb-2.5 text-[11px]">
              {secondaryKeys.slice(0, 4).map(m => (
                <span key={m.key} className="text-text-muted truncate">{m.label} <span className="font-medium text-text-secondary">{fmtSecondary(c, m.key)}</span></span>
              ))}
            </div>
          </div>
        )
      })}
    </div>
  )
}

/* ─── Proportion Bar ─── */
function ProportionCell({ value, sum, formatted, color = 'bg-text-muted', showGauge = true }: { value: number; sum: number; formatted: string; color?: string; showGauge?: boolean }) {
  const sharePct = sum > 0 ? (value / sum) * 100 : 0
  const sharePctLabel = sharePct.toFixed(0)
  return (
    <div className="relative flex items-center justify-end h-[18px]">
      {showGauge && (
        <div className={`absolute inset-y-0 left-0 rounded ${color} opacity-[0.13]`} style={{ width: `${Math.min(sharePct, 100)}%` }} />
      )}
      <span className="relative z-10 text-right text-[11px] font-medium text-text-primary whitespace-nowrap">
        {formatted} ({sharePctLabel}%)
      </span>
    </div>
  )
}

/* ─── List View ─── */
function makeListColumns(items: Candidate[], valueMode: ValueMode, onSqlTextClick: (c: Candidate) => void, selectedIds: Set<string>, onToggleSelect: (id: string) => void, allSelected: boolean, someSelected: boolean, onToggleAll: (checked: boolean) => void, aliasMap: Record<string, string>, onAliasChange: (sqlId: string, value: string) => void): ColumnDef<Candidate>[] {
  const isAvg = valueMode === 'avg'
  const metricVal = (row: Candidate, key: 'elapsed' | 'cpuTime' | 'logicalReads' | 'physicalReads') =>
    isAvg ? row[key] / Math.max(row.executions, 1) : row[key]

  const sumElapsed = items.reduce((s, c) => s + metricVal(c, 'elapsed'), 0)
  const sumCpu = items.reduce((s, c) => s + metricVal(c, 'cpuTime'), 0)
  const sumLogical = items.reduce((s, c) => s + metricVal(c, 'logicalReads'), 0)
  const sumPhysical = items.reduce((s, c) => s + metricVal(c, 'physicalReads'), 0)
  const sumExecs = items.reduce((s, c) => s + c.executions, 0)

  const suffix = isAvg ? ' /Exec' : ''
  const showGauge = !isAvg

  return [
    { key: 'sqlText', header: (
      <span className="inline-flex items-center gap-2">
        <input
          type="checkbox"
          checked={allSelected}
          ref={el => { if (el) el.indeterminate = someSelected && !allSelected }}
          onClick={e => e.stopPropagation()}
          onChange={e => onToggleAll(e.target.checked)}
          className="h-3.5 w-3.5 cursor-pointer"
        />
        SQL Text
      </span>
    ), width: 220, render: (_v, row) => (
      <div className="flex items-center gap-2">
        <input
          type="checkbox"
          checked={selectedIds.has(row.sqlId)}
          onClick={e => e.stopPropagation()}
          onChange={() => onToggleSelect(row.sqlId)}
          className="h-3.5 w-3.5 cursor-pointer shrink-0"
        />
        <button
          onClick={e => { e.stopPropagation(); onSqlTextClick(row) }}
          className="block w-full min-w-0 truncate font-mono text-[11px] text-code hover:text-code-dark hover:underline text-left"
          title={row.sqlText.replace(/\s+/g, ' ').trim()}
        >
          {row.sqlText.replace(/\s+/g, ' ').trim()}
        </button>
      </div>
    ) },
    { key: 'alias', header: '별칭', width: 140, render: (_v, row) => (
      <input
        type="text"
        defaultValue={aliasMap[row.sqlId] ?? row.alias ?? ''}
        onBlur={e => { onAliasChange(row.sqlId, e.target.value) }}
        onKeyDown={e => { if (e.key === 'Enter') (e.target as HTMLInputElement).blur() }}
        onClick={e => e.stopPropagation()}
        className="w-full bg-transparent border-0 border-b border-transparent hover:border-border focus:border-action focus:outline-none text-[11px] text-text-secondary px-0 py-0.5 truncate"
        style={{ maxWidth: 130 }}
      />
    ) },
    { key: 'sqlId', header: 'SQL ID', width: 160, render: (v, row) => (
      <div className="flex items-center gap-1.5">
        <span className="font-mono text-[11px] font-bold text-text-primary whitespace-nowrap">{String(v)}</span>
        {findTerminalWorkItem(row.sqlId) && (
          <span className="rounded px-1 py-0.5 text-[10px] font-medium bg-surface-muted text-text-secondary border border-border whitespace-nowrap">
            기존 결과 있음
          </span>
        )}
      </div>
    ) },
    { key: 'module', header: 'Module', width: 100, render: (v) => <span className="whitespace-nowrap text-[11px] text-text-secondary">{String(v)}</span> },
    { key: 'schemaName', header: 'Schema', width: 90, render: (v) => <span className="whitespace-nowrap text-[11px] text-text-secondary">{String(v)}</span> },
    { key: 'planHashValue', header: 'Plan Hash', width: 110, render: (v) => <span className="whitespace-nowrap font-mono text-[11px] text-text-muted">{String(v).slice(0, 10)}</span> },
    { key: 'elapsed', header: `Elapsed Time${suffix}`, width: 160, render: (_v, row) => <ProportionCell value={metricVal(row, 'elapsed')} sum={sumElapsed} formatted={formatMs(metricVal(row, 'elapsed'))} showGauge={showGauge} /> },
    { key: 'cpuTime', header: `CPU Time${suffix}`, width: 150, render: (_v, row) => <ProportionCell value={metricVal(row, 'cpuTime')} sum={sumCpu} formatted={formatMs(metricVal(row, 'cpuTime'))} showGauge={showGauge} /> },
    { key: 'logicalReads', header: `Logical Reads${suffix}`, width: 150, render: (_v, row) => <ProportionCell value={metricVal(row, 'logicalReads')} sum={sumLogical} formatted={formatNumber(Math.round(metricVal(row, 'logicalReads')))} showGauge={showGauge} /> },
    { key: 'physicalReads', header: `Physical Reads${suffix}`, width: 150, render: (_v, row) => <ProportionCell value={metricVal(row, 'physicalReads')} sum={sumPhysical} formatted={formatNumber(Math.round(metricVal(row, 'physicalReads')))} showGauge={showGauge} /> },
    { key: 'executions', header: 'Executions', width: 140, render: (_v, row) => <ProportionCell value={row.executions} sum={sumExecs} formatted={formatNumber(row.executions)} showGauge={showGauge} /> },
  ]
}

function ListView({ items, onSelect, onCreateWork, onRegisterException, onHover, valueMode, selectedIds, onToggleSelect, aliasMap, onAliasChange }: { items: Candidate[]; onSelect: (c: Candidate, initialTab?: DetailInitialTab) => void; onCreateWork: (c: Candidate) => void; onRegisterException: (c: Candidate) => void; onHover: (id: string | null) => void; valueMode: ValueMode; selectedIds: Set<string>; onToggleSelect: (id: string) => void; aliasMap: Record<string, string>; onAliasChange: (sqlId: string, value: string) => void }) {
  const onSqlTextClick = useCallback((c: Candidate) => {
    onSelect(c, 'sql')
  }, [onSelect])

  const allSelected = items.length > 0 && items.every(c => selectedIds.has(c.sqlId))
  const someSelected = selectedIds.size > 0 && !allSelected
  const onToggleAll = useCallback((checked: boolean) => {
    if (checked) items.forEach(c => { if (!selectedIds.has(c.sqlId)) onToggleSelect(c.sqlId) })
    else items.forEach(c => { if (selectedIds.has(c.sqlId)) onToggleSelect(c.sqlId) })
  }, [items, selectedIds, onToggleSelect])
  const baseColumns = useMemo(
    () => makeListColumns(items, valueMode, onSqlTextClick, selectedIds, onToggleSelect, allSelected, someSelected, onToggleAll, aliasMap, onAliasChange),
    [items, valueMode, onSqlTextClick, selectedIds, onToggleSelect, allSelected, someSelected, onToggleAll, aliasMap, onAliasChange]
  )
  const [columns, setColumns] = useState<ColumnDef<Candidate>[]>(() => baseColumns)

  // Update columns when items change (recalc proportions) but keep user's column order
  useEffect(() => {
    setColumns(prev => {
      const newMap = new Map(baseColumns.map(c => [c.key, c]))
      return prev
        .map(c => c.key === '_action' ? c : newMap.get(c.key))
        .filter((c): c is ColumnDef<Candidate> => !!c)
    })
  }, [baseColumns])

  const columnsWithAction = useMemo<ColumnDef<Candidate>[]>(() => [
    ...columns,
    {
      key: '_action',
      header: '',
      width: 76,
      resizable: false,
      draggable: false,
      render: (_v, row) => (
        <div className="flex items-center gap-0.5">
          <button
            onClick={e => { e.stopPropagation(); onRegisterException(row) }}
            className="rounded-md p-1 text-text-muted transition-all hover:bg-danger-light hover:text-danger"
            title="예외 등록"
          >
            <Ban className="h-4 w-4" />
          </button>
          <button
            onClick={e => { e.stopPropagation(); onCreateWork(row) }}
            className="rounded-md p-1 text-text-muted transition-all hover:bg-code-bg hover:text-code"
            title="튜닝작업 생성"
          >
            <Plus className="h-4 w-4" />
          </button>
        </div>
      ),
    },
  ], [columns, onCreateWork, onRegisterException])

  const handleColumnsChange = useCallback((newCols: ColumnDef<Candidate>[]) => {
    // Filter out the action column before saving
    setColumns(newCols.filter(c => c.key !== '_action'))
  }, [])

  return (
    <DataTable<Candidate>
      columns={columnsWithAction}
      data={items}
      rowKey="sqlId"
      onRowClick={(row) => onSelect(row, 'summary')}
      onRowHover={(row) => onHover(row ? (row as Candidate).sqlId : null)}
      onColumnsChange={handleColumnsChange}
    />
  )
}
