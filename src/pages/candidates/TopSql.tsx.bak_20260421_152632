  verified: { label: '튜닝완료', color: 'text-info', icon: Check },
  tuning: { label: '튜닝중', color: 'text-warning', icon: Loader2 },
  rejected: { label: '반려', color: 'text-danger', icon: AlertCircle },
  pending: { label: '대기', color: 'text-text-muted', icon: Clock },
}

/* ─── HistoryList (첫 건 + 펼치기) ─── */
function HistoryList({ records }: { records: SqlTuningRecord[] }) {
  const { openWorkDetail } = useWorkDetailPanel()
  const [expanded, setExpanded] = useState(false)
  const visible = expanded ? records : records.slice(0, 1)
  const rest = records.length - 1
  const fmtDate = (iso: string) => {
    const d = new Date(iso)
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`
  }
  return (
    <div className="space-y-1.5">
      {visible.map((rec) => {
        const statusCfg = TUNING_STATUS_CONFIG[rec.status] ?? TUNING_STATUS_CONFIG.pending
        const StatusIcon = statusCfg.icon
        return (
          <div
            key={rec.workItemId}
            onClick={() => openWorkDetail(rec.workItemId)}
            className="flex items-start gap-3 rounded-lg border border-border bg-white px-3 py-2.5 hover:bg-surface transition-colors cursor-pointer"
          >
            <div className={`mt-0.5 shrink-0 ${statusCfg.color}`}>
              <StatusIcon className="h-3.5 w-3.5" />
            </div>
            <div className="flex-1 min-w-0">
              <div className="flex items-center gap-2">
                <span className="text-xs font-semibold text-text-primary truncate">{rec.workName}</span>
                <span className={`text-[10px] font-semibold ${statusCfg.color}`}>{statusCfg.label}</span>
              </div>
              <div className="flex items-center gap-2 mt-0.5 text-[10px] text-text-muted">
                <span className="font-mono">{rec.workItemId}</span>
                <span>·</span>
                <span>{rec.batchId}</span>
                <span>·</span>
                <span>{fmtDate(rec.createdAt)}</span>
                {rec.recommendationType && (
                  <>
                    <span>·</span>
                    <span className="rounded bg-surface-muted px-1 py-px text-[10px] font-medium text-text-secondary">{rec.recommendationType}</span>
                  </>
                )}
              </div>
              {rec.improvementRate != null && (
                <div className="mt-0.5 text-[10px]">
                  <span className="text-text-muted">개선율 </span>
                  <span className="font-semibold text-success">{rec.improvementRate.toFixed(1)}%</span>
                </div>
              )}
              {rec.note && (
                <p className="mt-0.5 text-[10px] text-text-secondary">{rec.note}</p>
              )}
            </div>
            <button
              onClick={(e) => { e.stopPropagation(); openWorkDetail(rec.workItemId) }}
              className="shrink-0 rounded p-1 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors"
              title="작업 상세 이동"
            >
              <ArrowUpRight className="h-3 w-3" />
            </button>
          </div>
        )
      })}
      {rest > 0 && !expanded && (
        <button
          onClick={() => setExpanded(true)}
          className="w-full text-center py-1.5 text-[11px] text-text-muted hover:text-text-secondary transition-colors"
        >
          외 {rest}건 더 보기
        </button>
      )}
      {expanded && rest > 0 && (
        <button
          onClick={() => setExpanded(false)}
          className="w-full text-center py-1.5 text-[11px] text-text-muted hover:text-text-secondary transition-colors"
        >
          접기
        </button>
      )}
    </div>
  )
}

/* ─── SQL Detail Content (shared by SlidePanel & Popups) ─── */
export function SqlDetailContent({
  sql,
  onCreateWork,
  activeTab,
  initialTab: _initialTab = 'summary',
  onClose,
  onDetach,
  onMaximize,
  isMaximized,
  startTime: parentStartTime,
  endTime: parentEndTime,
}: {
  sql: Candidate
  onCreateWork: (c: Candidate) => void
  activeTab: SourceTab
  initialTab?: DetailInitialTab
  onClose?: () => void
  onDetach?: () => void
  onMaximize?: () => void
  isMaximized?: boolean
  startTime?: Date
  endTime?: Date
}) {
  const { colTerm: __ctxColTerm } = useObjectInfo()

  // 전체 SQL 본문 — 리스트 API 는 500자 preview 만 주므로 상세 진입 시 fulltext 별도 조회
  const [fullSqlText, setFullSqlText] = useState<string>(sql.sqlText)
  useEffect(() => {
    setFullSqlText(sql.sqlText)  // sql 바뀌면 우선 preview 로 초기화
    if (!sql.sqlId) return
    let aborted = false
    const qs = new URLSearchParams({ sql_id: sql.sqlId })
    // instance_id 는 매핑이 어려우니 기본값(INS-REPO) 에 맡김 (백엔드 기본)
    fetch(`${API_BASE}/api/sql/fulltext?${qs}`)
      .then(r => (r.ok ? r.json() : null))
      .then(d => {
        if (!aborted && d?.sql_text && typeof d.sql_text === 'string') {
          setFullSqlText(d.sql_text)
        }
      })
      .catch(() => { /* preview 유지 */ })
    return () => { aborted = true }
  }, [sql.sqlId, sql.sqlText])

  const [rightTab, setRightTab] = useState<'plan' | 'bind'>('plan')
  const containerRef = useRef<HTMLDivElement>(null)
  const [containerWidth, setContainerWidth] = useState(700)
  // Horizontal split ratio (left %) for wide mode
  const [splitRatio, setSplitRatio] = useState(50)
  const splitDragRef = useRef<{ startX: number; startRatio: number } | null>(null)
  // Vertical split ratio (top %) for narrow mode SQL Text / Plan
  const [vSplitRatio, setVSplitRatio] = useState(60)
  const vSplitDragRef = useRef<{ startY: number; startRatio: number } | null>(null)
  // Vertical section heights — flex basis in px; 0 = collapsed
  const [topHeight, setTopHeight] = useState(400)
  const vDragRef = useRef<{ startY: number; startH: number } | null>(null)

  // Fullview floating panels
  const [openFullviews, setOpenFullviews] = useState<Set<string>>(new Set())
  const [fullviewFocus, setFullviewFocus] = useState<string | null>(null)
  const openFullview = useCallback((type: string) => {
    setOpenFullviews(prev => new Set(prev).add(type))
    setFullviewFocus(type)
  }, [])
  const closeFullview = useCallback((type: string) => {
    setOpenFullviews(prev => { const next = new Set(prev); next.delete(type); return next })
  }, [])

  // Observe container width for responsive layout
  useEffect(() => {
    if (!containerRef.current) return
    const observer = new ResizeObserver((entries) => {
      for (const entry of entries) {
        setContainerWidth(entry.contentRect.width)
      }
    })
    observer.observe(containerRef.current)
    return () => observer.disconnect()
  }, [])

  const isWide = containerWidth >= 800

  const onSplitDragStart = useCallback((e: React.MouseEvent) => {
    e.preventDefault()
    splitDragRef.current = { startX: e.clientX, startRatio: splitRatio }
    const cw = containerRef.current?.clientWidth || 1
    const onMove = (ev: MouseEvent) => {
      if (!splitDragRef.current) return
      const delta = ev.clientX - splitDragRef.current.startX
      const pctDelta = (delta / cw) * 100
      setSplitRatio(Math.min(75, Math.max(25, splitDragRef.current.startRatio + pctDelta)))
    }
    const onUp = () => {
      splitDragRef.current = null
      document.removeEventListener('mousemove', onMove)
      document.removeEventListener('mouseup', onUp)
    }
    document.addEventListener('mousemove', onMove)
    document.addEventListener('mouseup', onUp)
  }, [splitRatio])

  const onVSplitDragStart = useCallback((e: React.MouseEvent) => {
    e.preventDefault()
    const container = (e.currentTarget as HTMLElement).parentElement
    const ch = container?.clientHeight || 1
    vSplitDragRef.current = { startY: e.clientY, startRatio: vSplitRatio }
    const onMove = (ev: MouseEvent) => {
      if (!vSplitDragRef.current) return
      const delta = ev.clientY - vSplitDragRef.current.startY
      const pctDelta = (delta / ch) * 100
      setVSplitRatio(Math.min(80, Math.max(20, vSplitDragRef.current.startRatio + pctDelta)))
    }
    const onUp = () => {
      vSplitDragRef.current = null
      document.removeEventListener('mousemove', onMove)
      document.removeEventListener('mouseup', onUp)
    }
    document.addEventListener('mousemove', onMove)
    document.addEventListener('mouseup', onUp)
  }, [vSplitRatio])

  const onVDragStart = useCallback((_target: 'sqlplan', e: React.MouseEvent) => {
    e.preventDefault()
    vDragRef.current = { startY: e.clientY, startH: topHeight }
    const onMove = (ev: MouseEvent) => {
      if (!vDragRef.current) return
      const delta = ev.clientY - vDragRef.current.startY
      setTopHeight(Math.max(200, vDragRef.current.startH + delta))
    }
    const onUp = () => {
      vDragRef.current = null
      document.removeEventListener('mousemove', onMove)
      document.removeEventListener('mouseup', onUp)
    }
    document.addEventListener('mousemove', onMove)
    document.addEventListener('mouseup', onUp)
  }, [topHeight])

  const detailTrendResult = useMemo(() => {
    const st = parentStartTime || new Date('2026-03-24T00:00:00')
    const et = parentEndTime || new Date('2026-03-24T23:59:59')
    return generateSqlDetailTrend(sql.sqlId, st, et)
  }, [sql.sqlId, parentStartTime, parentEndTime])




  // Plan Hash 선택 — Oracle V$SQL_PLAN API 연동
  const [apiPlanHashes, setApiPlanHashes] = useState<string[]>([])
  const [apiPlanRows, setApiPlanRows] = useState<PlanRow[]>([])
  const [apiBindRows, setApiBindRows] = useState<BindVariable[]>([])

  const availablePlanHashes = useMemo(() => {
    if (apiPlanHashes.length > 0) return apiPlanHashes
    const fromTrend = detailTrendResult.allPlanHashes
    if (fromTrend.length > 0) return fromTrend
    return []
  }, [apiPlanHashes, detailTrendResult.allPlanHashes])
  const [selectedPlanHash, setSelectedPlanHash] = useState<string>(() => availablePlanHashes[0] || '')

  // V$SQL_PLAN API 호출
  useEffect(() => {
    const source = activeTab === 'awr' ? 'awr' : 'v$sql'
    const url = `${API_BASE}/api/sql-plan?sql_id=${encodeURIComponent(sql.sqlId)}${selectedPlanHash ? '&plan_hash=' + encodeURIComponent(selectedPlanHash) : ''}&source=${source}`
    fetch(url)
      .then(r => r.json())
      .then((data: { planHashes: string[]; rows: PlanRow[] }) => {
        setApiPlanHashes(data.planHashes)
        setApiPlanRows(data.rows)
        if (!selectedPlanHash && data.planHashes.length > 0) {
          setSelectedPlanHash(data.planHashes[0])
        }
      })
      .catch(() => { setApiPlanRows([]); setApiPlanHashes([]) })
  }, [sql.sqlId, selectedPlanHash])

  // V$SQL_BIND_CAPTURE API 호출
  useEffect(() => {
    const bindSource = activeTab === 'awr' ? 'awr' : 'v$sql'
    fetch(`${API_BASE}/api/sql-binds?sql_id=${encodeURIComponent(sql.sqlId)}&source=${bindSource}`)
      .then(r => r.json())
      .then((data: BindVariable[]) => setApiBindRows(data))
      .catch(() => setApiBindRows([]))
  }, [sql.sqlId])

  const planRows = apiPlanRows
  const bindRows = apiBindRows

  // Plan을 텍스트로 변환 (복사용)
  const planToText = () =>
    planRows.map(r => `${' '.repeat((r.depth ?? 0) * 2)}${r.id}\t${r.operation}\t${r.name || ''}\t${r.rows ?? ''}\t${r.cost ?? ''}`).join('\n')

  // Bind를 텍스트로 변환 (복사용)
  const bindToText = () =>
    bindRows.map(b => `${b.name}\t${b.type}\t${b.value}`).join('\n')

  // 튜닝이력
  const tuningHistoryKey = makeTuningHistoryKey(sql.sqlId, sql.instanceName)
  const tuningRecords: SqlTuningRecord[] = sqlTuningHistory[tuningHistoryKey] || []


  // Plan/Bind 렌더 공용 테이블
  const renderPlanTable = () =>
    planRows.length > 0 ? (
      <table className="w-full text-xs">
        <thead className="sticky top-0 bg-surface-alt z-10">
          <tr className="border-b border-surface-muted">
            <th className="px-2 py-1.5 text-left text-[11px] font-normal text-text-muted">Id</th>
            <th className="px-2 py-1.5 text-left text-[11px] font-normal text-text-muted">Operation</th>
            <th className="px-2 py-1.5 text-left text-[11px] font-normal text-text-muted">Name</th>
            <th className="px-2 py-1.5 text-right text-[11px] font-normal text-text-muted">Rows</th>
            <th className="px-2 py-1.5 text-right text-[11px] font-normal text-text-muted">Cost</th>
          </tr>
        </thead>
        <tbody>{planRows.map(r => (
          <tr key={r.id} className="border-b border-surface-muted hover:bg-surface">
            <td className="px-2 py-1 text-text-muted">{r.id}</td>
            <td className="px-2 py-1 text-text-primary" style={{ paddingLeft: `${(r.depth ?? 0) * 16 + 8}px` }}>{r.operation}</td>
            <td className="px-2 py-1 text-text-secondary">{r.name}</td>
            <td className="px-2 py-1 text-right text-text-secondary">{r.rows != null ? formatNumber(r.rows) : ''}</td>
            <td className="px-2 py-1 text-right text-text-secondary">{r.cost != null ? formatNumber(r.cost) : ''}</td>
          </tr>
        ))}</tbody>
      </table>
    ) : (<div className="px-4 py-6 text-center text-xs text-text-muted">실행 계획 데이터가 없습니다.</div>)

  const renderBindTable = () =>
    bindRows.length > 0 ? (
      <table className="w-full text-xs">
        <thead className="sticky top-0 bg-surface-alt z-10">
          <tr className="border-b border-surface-muted">
            <th className="px-2 py-1.5 text-left text-[11px] font-normal text-text-muted">Name</th>
            <th className="px-2 py-1.5 text-left text-[11px] font-normal text-text-muted">Type</th>
            <th className="px-2 py-1.5 text-left text-[11px] font-normal text-text-muted">Value</th>
            <th className="px-2 py-1.5 text-left text-[11px] font-normal text-text-muted">Captured</th>
          </tr>
        </thead>
        <tbody>{bindRows.map((b, i) => (
          <tr key={i} className="border-b border-surface-muted hover:bg-surface">
            <td className="px-2 py-1 font-mono text-text-primary">{b.name}</td>
            <td className="px-2 py-1 text-text-secondary">{b.type}</td>
            <td className="px-2 py-1 font-mono text-text-primary">{b.value}</td>
            <td className="px-2 py-1 text-text-muted">{b.capturedAt}</td>
          </tr>
        ))}</tbody>
      </table>
    ) : (<div className="px-4 py-6 text-center text-xs text-text-muted">바인드 변수 데이터가 없습니다.</div>)

  // Right panel header with copy + fullview
  const rightPanelHeader = (
    <div className="flex items-center justify-between mb-1.5 shrink-0">
      <div className="flex items-center gap-1.5">
        <button onClick={() => setRightTab('plan')} className={`rounded-md px-2.5 py-1 text-xs font-medium transition-colors ${rightTab === 'plan' ? 'bg-action text-white' : 'text-text-muted hover:bg-surface-muted hover:text-text-secondary'}`}>Plan</button>
        <button onClick={() => setRightTab('bind')} className={`rounded-md px-2.5 py-1 text-xs font-medium transition-colors ${rightTab === 'bind' ? 'bg-action text-white' : 'text-text-muted hover:bg-surface-muted hover:text-text-secondary'}`}>Bind</button>
        {rightTab === 'plan' && availablePlanHashes.length > 1 && (
          <select
            value={selectedPlanHash}
            onChange={e => setSelectedPlanHash(e.target.value)}
            className="rounded-md border border-border bg-white px-2 py-0.5 text-[11px] font-mono text-text-primary focus:outline-none focus:ring-1 focus:ring-action/30"
          >
            {availablePlanHashes.map((hash, i) => (
              <option key={hash} value={hash}>Plan#{i + 1} ({hash.slice(0, 8)})</option>
            ))}
          </select>
        )}
      </div>
      <div className="flex items-center gap-0.5">
        <CopyButton text={rightTab === 'plan' ? planToText() : bindToText()} />
        <button
          onClick={() => rightTab === 'plan' ? openFullview('plan') : openFullview('bind')}
          className="rounded p-1 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors"
          title="전체보기"
        >
          <Maximize2 className="h-3 w-3" />
        </button>
      </div>
    </div>
  )

  return (
    <div ref={containerRef} className="space-y-3">
      {/* Header */}
      {onClose ? (
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-2">
            <span className="font-mono text-sm font-semibold text-text-primary">{sql.sqlId}</span>
            <SourceBadge source={sql.source} />
            <span className="text-border">·</span>
            <span className="text-[11px] text-text-muted">{sql.instanceName}</span>
            <span className="text-border">·</span>
            <span className="text-[11px] text-text-muted">{sql.schemaName}</span>
          </div>
          <div className="flex items-center gap-1">
            <button
              onClick={() => onCreateWork(sql)}
              className="inline-flex items-center gap-1 rounded-md bg-action px-2.5 py-1 text-xs font-medium text-white hover:bg-action-hover transition-colors"
            >
              <Plus className="h-3.5 w-3.5" />
              튜닝요청
            </button>
            {onDetach && (
              <button onClick={onDetach} className="rounded-md p-1.5 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors" title="팝업으로 분리">
                <ExternalLink className="h-4 w-4" />
              </button>
            )}
            {onMaximize && (
              <button onClick={onMaximize} className="rounded-md p-1.5 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors" title={isMaximized ? '원래 크기' : '최대화'}>
                {isMaximized ? <Minimize2 className="h-4 w-4" /> : <Maximize2 className="h-4 w-4" />}
              </button>
            )}
            <button onClick={onClose} className="rounded-md p-1.5 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors" title="닫기 (Esc)">
              <X className="h-4 w-4" />
            </button>
          </div>
        </div>
      ) : (
        <div className="flex items-center gap-2">
          <span className="text-[11px] text-text-muted">{sql.instanceName}</span>
          <span className="text-border">·</span>
          <span className="text-[11px] text-text-muted">{sql.schemaName}</span>
          <div className="ml-auto">
            <button
              onClick={() => onCreateWork(sql)}
              className="inline-flex items-center gap-1 rounded-md bg-action px-2.5 py-1 text-xs font-medium text-white hover:bg-action-hover transition-colors"
            >
              <Plus className="h-3.5 w-3.5" />
              튜닝요청
            </button>
          </div>
        </div>
      )}

      {/* ── 성능 요약 ── */}
      <div className="flex items-center gap-x-3 rounded-lg border border-border bg-white px-3 py-2 text-[11px]">
        <span className="text-text-muted">Elapsed <span className="font-semibold text-text-primary">{formatMs(sql.elapsed)}</span></span>
        <span className="text-border">|</span>
        <span className="text-text-muted">CPU <span className="font-semibold text-text-primary">{formatMs(sql.cpuTime)}</span></span>
        <span className="text-border">|</span>
        <span className="text-text-muted">LReads <span className="font-semibold text-text-primary">{formatNumber(sql.logicalReads)}</span></span>
        <span className="text-border">|</span>
        <span className="text-text-muted">PReads <span className="font-semibold text-text-primary">{formatNumber(sql.physicalReads)}</span></span>
        <span className="text-border">|</span>
        <span className="text-text-muted">Execs <span className="font-semibold text-text-primary">{formatNumber(sql.executions)}</span></span>
      </div>

      {/* ── Section: SQL Text + Plan/Bind ── */}
      <div style={{ height: topHeight }} className="flex flex-col min-h-0">
        {isWide ? (
          <div className="flex flex-1 min-h-0">
            {/* Left: SQL Text */}
            <div className="flex flex-col min-w-0" style={{ width: `${splitRatio}%` }}>
              <div className="flex items-center justify-between mb-1.5 shrink-0">
                <div className="flex items-center gap-2">
                  <div className="w-0.5 h-3.5 bg-action rounded-full" />
                  <span className="text-[11px] font-semibold text-text-secondary">SQL Text</span>
                </div>
                <div className="flex items-center gap-0.5">
                  <CopyButton text={fullSqlText} />
                  <button onClick={() => openFullview('sql')} className="rounded p-1 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors" title="전체보기">
                    <Maximize2 className="h-3 w-3" />
                  </button>
                </div>
              </div>
              <div className="flex-1 min-h-0 rounded-lg border border-border bg-surface-alt p-3 overflow-auto" data-sql-source={fullSqlText}>
                <pre className="whitespace-pre-wrap font-mono text-[13px] leading-[1.6]">{highlightSQL(fullSqlText, __ctxColTerm)}</pre>
              </div>
            </div>
            {/* Horizontal divider */}
            <div className="shrink-0 flex items-center justify-center w-2 cursor-col-resize group hover:bg-surface-muted rounded mx-0.5 transition-colors" onMouseDown={onSplitDragStart}>
              <div className="h-8 w-0.5 rounded-full bg-border group-hover:bg-action transition-colors" />
            </div>
            {/* Right: Plan/Bind */}
            <div className="flex flex-col min-w-0" style={{ width: `${100 - splitRatio}%` }}>
              {rightPanelHeader}
              <div className="flex-1 min-h-0 rounded-lg border border-border bg-white overflow-auto">
                {rightTab === 'plan' ? renderPlanTable() : renderBindTable()}
              </div>
            </div>
          </div>
        ) : (
          <div className="flex flex-col flex-1 min-h-0">
            {/* SQL Text */}
            <div className="flex flex-col min-h-0" style={{ height: `${vSplitRatio}%` }}>
              <div className="flex items-center justify-between mb-1.5 shrink-0">
                <div className="flex items-center gap-2">
                  <div className="w-0.5 h-3.5 bg-action rounded-full" />
                  <span className="text-[11px] font-semibold text-text-secondary">SQL Text</span>
                </div>
                <div className="flex items-center gap-0.5">
                  <CopyButton text={fullSqlText} />
                  <button onClick={() => openFullview('sql')} className="rounded p-1 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors" title="전체보기">
                    <Maximize2 className="h-3 w-3" />
                  </button>
                </div>
              </div>
              <div className="flex-1 min-h-0 rounded-lg border border-border bg-surface-alt p-3 overflow-auto" data-sql-source={fullSqlText}>
                <pre className="whitespace-pre-wrap font-mono text-[13px] leading-[1.6]">{highlightSQL(fullSqlText, __ctxColTerm)}</pre>
              </div>
            </div>
            {/* Vertical divider */}
