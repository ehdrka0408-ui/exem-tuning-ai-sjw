// ─── 상수 ─────────────────────────────────────────
// ─── Target DB/Schema 메타 (backend API) — DBMS agnostic ────────────
const TARGET_API_BASE = (import.meta as unknown as { env: { VITE_API_BASE?: string } }).env.VITE_API_BASE || 'http://10.10.45.119:8000'
interface TargetSchemaMeta { id: number; schema_name: string; display_name?: string | null }
interface TargetDatabaseMeta { id: number; instance_id: string; db_name: string; display_name?: string | null; schemas: TargetSchemaMeta[] }
interface TargetInstanceMeta { instance_id: string; databases: TargetDatabaseMeta[] }

// Fallback 상수 — API 실패 시에만 사용
const INSTANCES = ['INS-REPO']
const SCHEMAS = ['SALES', 'FIN', 'HR', 'MXGREPO', 'MXGREPO2']
const MODULES = ['OMS_BATCH', 'OMS_ONLINE', 'HR_WEB', 'HR_ADMIN', 'FIN_CORE', 'SALES_RPT', 'SALES_API', 'ETL_NIGHTLY']

type SqlWorkloadType = 'oltp' | 'batch' | 'adhoc'
const WORKLOAD_OPTIONS: { value: SqlWorkloadType; label: string; defaultDaily: string }[] = [
  { value: 'oltp', label: 'OLTP', defaultDaily: '1500' },
  { value: 'batch', label: 'BATCH', defaultDaily: '50' },
  { value: 'adhoc', label: 'AD HOC', defaultDaily: '5' },
]

const TUNING_STEPS = [
  { label: 'SQL 구문 분석', desc: 'SQL 구조와 테이블 관계를 파악하고 있습니다' },
  { label: '실행계획 수집', desc: '현재 실행계획을 분석하고 있습니다' },
  { label: '대안 생성', desc: 'AI가 튜닝 대안을 탐색하고 있습니다' },
  { label: '검증 실행', desc: '대안 SQL의 성능을 측정하고 있습니다' },
  { label: '결과 정리', desc: '튜닝 결과를 정리하고 있습니다' },
]

// ─── 타입 ─────────────────────────────────────────
type Phase = 'idle' | 'tuning' | 'done'

// ─── Mock 튜닝 결과 생성 ─────────────────────────────
function generateMockResult(itemId: string, sqlText: string, item: WorkItem) {
  const planId = `${itemId}-A`
  const origE = item.originalElapsed
  const origB = item.originalBuffers
  const rate = 60 + Math.floor(Math.random() * 30)
  const tunedE = Math.round(origE * (1 - rate / 100))
  const tunedB = Math.round(origB * (1 - rate / 100))

  const tunedSql = `/* 튜닝 적용 — 인덱스 활용 최적화 */\n${sqlText.replace(/SELECT/i, 'SELECT /*+ INDEX_RS_ASC(t1) */')}`

  workRecommendations[itemId] = {
    workItemId: itemId,
    selectedPlanId: planId,
    plans: [{
      id: planId,
      label: '인덱스안',
      types: ['index', 'hint'],
      verifyType: 'actual',
      improvementRate: -rate,
      summary: `인덱스 생성 + 힌트 적용으로 ${rate}% 성능 개선`,
      rationale: [
        'Full Table Scan → Index Range Scan 전환',
        '불필요한 정렬 제거로 Buffer Gets 절감',
        '실측 기반 검증 완료',
      ],
      originalElapsed: origE,
      tunedElapsed: tunedE,
      originalBuffers: origB,
      tunedBuffers: tunedB,
      originalDiskReads: Math.round(origB * 0.3),
      tunedDiskReads: Math.round(tunedB * 0.1),
      originalPlanText: `SQL_ID ${item.sqlId}, child number 0\nPlan hash value: ${Math.floor(Math.random() * 9999999999)}\n\n| Id | Operation           | Name | Starts | E-Rows | A-Rows | A-Time       | Buffers |\n|  0 | SELECT STATEMENT    |      |      1 |        |   3000 | 00:00:${(origE / 1000).toFixed(2)} |  ${origE} |\n|  1 |  HASH JOIN          |      |      1 |   5000 |   5000 | 00:00:${(origE / 1000).toFixed(2)} |  ${origB} |\n|  2 |   TABLE ACCESS FULL | T1   |      1 |  50000 |  50000 | 00:00:01.20 |   ${Math.round(origB * 0.6)} |\n|  3 |   TABLE ACCESS FULL | T2   |      1 |  10000 |  10000 | 00:00:00.80 |   ${Math.round(origB * 0.4)} |`,
      tunedPlanText: `SQL_ID ${item.sqlId}, child number 1\nPlan hash value: ${Math.floor(Math.random() * 9999999999)}\n\n| Id | Operation                     | Name       | Starts | E-Rows | A-Rows | A-Time       | Buffers |\n|  0 | SELECT STATEMENT              |            |      1 |        |   3000 | 00:00:${(tunedE / 1000).toFixed(2)} |  ${tunedB} |\n|  1 |  NESTED LOOPS                 |            |      1 |   5000 |   5000 | 00:00:${(tunedE / 1000).toFixed(2)} |  ${tunedB} |\n| *2 |   INDEX RANGE SCAN            | IDX_T1_NEW |      1 |   5000 |   5000 | 00:00:00.01 |    ${Math.round(tunedB * 0.1)} |\n|  3 |   TABLE ACCESS BY INDEX ROWID | T1         |   5000 |      1 |   5000 | 00:00:00.02 |    ${Math.round(tunedB * 0.3)} |\n| *4 |   INDEX RANGE SCAN            | IDX_T2_REF |   5000 |      1 |   5000 | 00:00:00.01 |    ${Math.round(tunedB * 0.2)} |\n|  5 |   TABLE ACCESS BY INDEX ROWID | T2         |   5000 |      1 |   5000 | 00:00:00.00 |    ${Math.round(tunedB * 0.1)} |`,
      tunedSqlText: tunedSql,
      indexDdl: `CREATE INDEX IDX_T1_NEW ON T1 (col1, col2) TABLESPACE USERS;`,
      bindSetId: undefined,
    }],
  }

  const bindMatches = sqlText.match(/:[a-zA-Z_]\w*/g)
  if (bindMatches && bindMatches.length > 0) {
    const uniqueBinds = [...new Set(bindMatches)]
    workBindSets[itemId] = {
      workItemId: itemId,
      bindSensitive: false,
      sets: [{
        id: `BS-${itemId}-1`,
        capturedAt: new Date().toISOString(),
        source: 'V$SQL' as const,
        variables: uniqueBinds.map(name => ({
          name, type: 'VARCHAR2', value: 'sample_value',
        })),
      }],
    }
  }

  const allItems = [...workItems, ...getNewV1Items()]
  const target = allItems.find(w => w.id === itemId)
  if (target) {
    target.status = 'approval_pending'
    target.executionResult = 'completed'
    target.tunedElapsed = tunedE
    target.tunedBuffers = tunedB
  }
  return target
}

function generateSqlId(sql: string): string {
  let hash = 0
  for (let i = 0; i < sql.length; i++) {
    hash = ((hash << 5) - hash + sql.charCodeAt(i)) | 0
  }
  return Math.abs(hash).toString(16).slice(0, 8).padStart(8, '0')
}

// ─── 셀렉트 컴포넌트 ─────────────────────────────
