                {formatted ? 'Format ON' : 'Format'}
              </button>
            )}
            <div className="flex items-center gap-2 text-[10px] text-slate-400">
              <span className="flex items-center gap-1"><span className="w-2 h-0.5 bg-blue-400 rounded" />변경됨</span>
            </div>
