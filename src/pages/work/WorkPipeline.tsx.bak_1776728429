    setPanelItem(item)
  }, [enterWorkspace])


  const navigateToBatchItems = useCallback((batch: BatchGroup) => {
    setExpandedBatchId(prev => prev === batch.batchId ? null : batch.batchId)
  }, [])

  // ─── 렌더 ───────────────────────────────────────
  const selectedTunedCount = [...selectedIds].filter(id => {
    const it = filteredItems.find(w => w.id === id)
    return it && it.status === 'approval_pending'
  }).length

  return (
    <div className={`flex flex-col h-[calc(100vh/1.1-40px)] overflow-hidden ${pageView === 'list' ? '-m-6 p-6 space-y-3' : '-m-6'}`}>

      {/* ═══ WORKSPACE 뷰 — 인라인 워크벤치 (SlidePanel 아님) ═══ */}
      {pageView === 'workspace' && workspaceItem && (
        <WorkbenchContent
          item={workspaceItem}
          filteredItems={filteredItems}
          getStatus={getStatus}
          onItemSelect={(item) => setWorkspaceItem(item)}
          onClose={exitWorkspace}
          onStatusChange={(id, status) => setStatusOverrides(prev => ({ ...prev, [id]: status }))}
          onReject={(item) => {
            setRejectTarget(item)
            rejectConfirmedRef.current = null
          }}
          onShowToast={showToast}
          onConfirmAction={setConfirmAction}
          onDirectInputCreated={(id) => {
            setHighlightId(id)
            exitWorkspace()
          }}
          onNavigateToExisting={(id) => {
