// ─── 별칭 셀: 로컬 state로 키 입력을 처리해 부모 재렌더 방지 ─────────
const AliasCell = memo(function AliasCell({ row }: { row: WorkItem }) {
  const initial = getAlias(row.id) ?? row.alias ?? ''
  const [editing, setEditing] = useState(false)
  const [value, setValue] = useState(initial)

  // override store가 외부에서 바뀌면 displayed value 동기화 (편집 중이 아닐 때만)
  const latest = getAlias(row.id) ?? row.alias ?? ''
  useEffect(() => {
    if (!editing) setValue(latest)
  }, [latest, editing])

  const commit = () => {
    setEditing(false)
    if (value === latest) return
    void setAlias(row.id, value, row.sqlId)
  }

  if (editing) {
    return (
      <input
        autoFocus
        value={value}
        onChange={(e) => setValue(e.target.value)}
        onClick={(e) => e.stopPropagation()}
        onKeyDown={(e) => {
          e.stopPropagation()
          if (e.key === 'Enter') { e.preventDefault(); commit() }
          if (e.key === 'Escape') { e.preventDefault(); setValue(latest); setEditing(false) }
        }}
        onBlur={commit}
        className="w-[150px] text-[11px] px-1.5 py-0.5 rounded border border-action bg-white focus:outline-none"
        placeholder="별칭 입력"
      />
    )
  }
  return (
    <span
      role="button"
      title={latest || ''}
      onClick={(e) => { e.stopPropagation(); setValue(latest); setEditing(true) }}
      className="text-[11px] text-text-secondary truncate block max-w-[150px] cursor-text hover:bg-surface-alt hover:text-text-primary rounded px-1 py-0.5"
    >
      {latest || <span className="text-text-muted/50">—</span>}
    </span>
  )
})

