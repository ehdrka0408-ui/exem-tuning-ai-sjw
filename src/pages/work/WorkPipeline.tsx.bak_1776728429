function computeDateRange7d(): { start: Date; end: Date } {
  // 기본 조회 범위: 최근 60일 (mock/시드 데이터가 7일 범위 밖이면 리스트가 비어 보이는 이슈 방지)
  const now = new Date()
  const today = new Date(now.getFullYear(), now.getMonth(), now.getDate())
  return {
    start: new Date(today.getTime() - 59 * 86400000),
    end: new Date(today.getFullYear(), today.getMonth(), today.getDate(), 23, 59, 59),
  }
}

function fmtIsoDate(d: Date): string {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`
}

type PresetKey = 'auto_today' | 'tuned_review'

interface AppliedFilters {
  dateStart: string
  dateEnd: string
  instance: string
  sqlId: string
  sqlText: string
  requester: string
  schemas: string[]
  modules: string[]
  chips: FilterChip[]
  freeText: string
  presets: PresetKey[]
}


// ─── 헬퍼 ─────────────────────────────────────────
function formatDate(iso: string): string {
  const d = new Date(iso)
  return `${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`
}

// ─── 메인 컴포넌트 ──────────────────────────────────
export default function WorkPipeline() {
  // ─── 하이라이트 (TopSql에서 작업 생성 후 이동 시) ───
  const location = useLocation()
  const navigate = useNavigate()
  const [searchParams, setSearchParams] = useSearchParams()
  const [highlightId, setHighlightId] = useState<string | null>(null)
  const [queueOrderVersion, setQueueOrderVersion] = useState(0)

  useEffect(() => {
    const handler = () => setQueueOrderVersion(v => v + 1)
    window.addEventListener('queueOrderChange', handler)
    return () => window.removeEventListener('queueOrderChange', handler)
  }, [])

  useEffect(() => {
    const state = location.state as { highlightItemId?: string; openItemId?: string } | null
    if (!state) return
    window.history.replaceState({}, '')
    if (state.highlightItemId) {
      setHighlightId(state.highlightItemId)
      const timer = setTimeout(() => setHighlightId(null), 4000)
      return () => clearTimeout(timer)
    }
    if (state.openItemId) {
      const allItems = [...workItems, ...getNewV1Items()]
      const target = allItems.find(w => w.id === state.openItemId)
      if (target) setPanelItem(target)
    }
  }, [location.state])

  // URL ?detail=ITEM_ID → 슬라이드 패널 자동 열기 (새 탭에서 열기용)
  useEffect(() => {
    const detailId = searchParams.get('detail')
    if (!detailId) return
    const allItems = [...workItems, ...getNewV1Items()]
    const target = allItems.find(w => w.id === detailId)
    if (target) setPanelItem(target)
    setSearchParams({}, { replace: true })
  }, [searchParams, setSearchParams])

  // scroll into view when highlight row renders
  useEffect(() => {
    if (!highlightId) return
    // small delay to let DataTable render the row
    const raf = requestAnimationFrame(() => {
      const el = document.querySelector('.highlight-new-item')
      el?.scrollIntoView({ behavior: 'smooth', block: 'center' })
    })
    return () => cancelAnimationFrame(raf)
  }, [highlightId])

  // 퀵 프리셋 (현재 비어있음 — 하위 호환 위해 state만 유지)
  const [activePresets] = useState<Set<PresetKey>>(new Set())

  // 뷰 모드
  const [viewMode, setViewMode] = useState<'items' | 'batches'>('items')
  const [expandedBatchId, setExpandedBatchId] = useState<string | null>(null)
  // 배치 보기: 시간축 필터
  // 배치뷰 기간 칩은 상단 TimeRangePicker(startTime/endTime)와 양방향 동기화
  // 칩 상태는 별도 저장하지 않고 startTime/endTime에서 파생

  // 예외 스토어 변경 tick (리렌더 트리거)
  const [exceptionTick, setExceptionTick] = useState(0)
  useEffect(() => subscribeSqlExceptions(() => setExceptionTick(t => t + 1)), [])
  const [aliasTick, setAliasTick] = useState(0)
  useEffect(() => subscribeAlias(() => setAliasTick(t => t + 1)), [])

  // 튜닝 진행률 애니메이션 tick — 2.5초마다 진척 (데모용)
  const [tuningTick, setTuningTick] = useState(0)
  useEffect(() => {
    const id = setInterval(() => setTuningTick(t => t + 1), 2500)
    return () => clearInterval(id)
  }, [])

  // 인라인 상태 변경 추적
  const [statusOverrides, setStatusOverrides] = useState<Record<string, WorkItem['status']>>({})
  const getStatus = useCallback((item: WorkItem) => statusOverrides[item.id] ?? item.status, [statusOverrides])

  // 전역 상태 오버라이드 (알림 재시도 등) 구독
  useEffect(() => {
    const handler = () => {
      const overrides = getGlobalStatusOverrides()
      if (overrides.size === 0) return
      setStatusOverrides(prev => {
        const merged = { ...prev }
        overrides.forEach((status, id) => { merged[id] = status })
        return merged
      })
    }
    window.addEventListener('globalStatusOverrideChange', handler)
    return () => window.removeEventListener('globalStatusOverrideChange', handler)
  }, [])

  // 선택
  const [selectedIds, setSelectedIds] = useState<Set<string>>(new Set())

  // 토스트
  const [toast, setToast] = useState<string | null>(null)
  const showToast = (msg: string) => {
    setToast(msg)
    setTimeout(() => setToast(null), 4000)
  }

  // 모달
  const [confirmAction, setConfirmAction] = useState<null | {
    title: string; message?: string; variant: 'danger' | 'warning'; onConfirm: () => void; item?: WorkItem
  }>(null)
  const [rejectTarget, setRejectTarget] = useState<WorkItem | null>(null)
  const [rejectReason, setRejectReason] = useState('')
  const rejectConfirmedRef = useRef<(() => void) | null>(null)

  // 페이지 뷰: list(목록+peek) vs workspace(인라인 워크벤치)
  const [pageView, setPageView] = useState<'list' | 'workspace'>('list')
  const [workspaceItem, setWorkspaceItem] = useState<WorkItem | null>(null)

  // 슬라이드 패널 (peek 전용 — 좁은 모드만)
  const [panelItem, setPanelItem] = useState<WorkItem | null>(null)
  const [panelMode, setPanelMode] = useState<PanelMode>('slide')
  // panelWidthPx 제거 — workspace 전환 시 onWidthChange에서 직접 처리

  // workspace 진입
  const enterWorkspace = useCallback((item: WorkItem) => {
    setPanelItem(null) // peek 닫기
    setWorkspaceItem(item)
    setPageView('workspace')
  }, [])

  // workspace 이탈
  const exitWorkspace = useCallback(() => {
    setPageView('list')
    setWorkspaceItem(null)
  }, [])

  // SQL 전체보기 모달
  const [sqlPreview, setSqlPreview] = useState<WorkItem | null>(null)

  // 컬럼 토글 + 정렬
  const DEFAULT_HIDDEN = new Set(['selectionSource', '_selectionReason', 'estimatedDailyExec', 'requestedBy', 'schemaName', 'module'])
  const [hiddenCols, setHiddenCols] = useState<Set<string>>(() => new Set(DEFAULT_HIDDEN))
  const [colToggleOpen, setColToggleOpen] = useState(false)
  const colToggleRef = useRef<HTMLDivElement>(null)
  const [sortState, setSortState] = useState<SortState>({ key: 'createdAt', direction: 'desc' })
  const [columnOrder, setColumnOrder] = useState<ColumnDef<WorkItem>[] | null>(null)

  // 조회조건 바
  const [startTime, setStartTime] = useState<Date>(() => computeDateRange7d().start)
  const [endTime, setEndTime] = useState<Date>(() => computeDateRange7d().end)
  const [selectedInstance, setSelectedInstance] = useState('')
  const [sqlIdQuery, setSqlIdQuery] = useState('')
  const [sqlTextQuery, setSqlTextQuery] = useState('')
  const [requesterQuery, setRequesterQuery] = useState('')
  const [schemas, setSchemas] = useState<string[]>([])
  const [modules, setModules] = useState<string[]>([])
  // filterExpanded removed — always show filters inline
  const [directInputOpen, setDirectInputOpen] = useState(false)

  // Property filter bar
  const [filterChips, setFilterChips] = useState<FilterChip[]>([])
  const [freeText, setFreeText] = useState('')
  const [filterBarFocused, setFilterBarFocused] = useState(false)
  const [filterStep, setFilterStep] = useState<'property' | 'value'>('property')
  const [selectedFilterProp, setSelectedFilterProp] = useState<FilterProperty | null>(null)
  const [filterQuery, setFilterQuery] = useState('')
  const filterBarRef = useRef<HTMLDivElement>(null)
  const filterInputRef = useRef<HTMLInputElement>(null)

  // Applied filters (조회 시 갱신)
  const [applied, setApplied] = useState<AppliedFilters>(() => {
    const range = computeDateRange7d()
    return { dateStart: fmtIsoDate(range.start), dateEnd: fmtIsoDate(range.end), instance: '', sqlId: '', sqlText: '', requester: '', schemas: [], modules: [], chips: [], freeText: '', presets: [] }
  })

  // 상태 필터
  const [statusFilter, setStatusFilter] = useState<WorkItem['status'] | 'all'>('all')

  // 필터바 외부 클릭 닫기
  useEffect(() => {
    if (!filterBarFocused) return
    const handler = (e: MouseEvent) => {
      if (filterBarRef.current && !filterBarRef.current.contains(e.target as Node)) {
        setFilterBarFocused(false)
        setFilterStep('property')
        setSelectedFilterProp(null)
        setFilterQuery('')
      }
    }
    document.addEventListener('mousedown', handler)
    return () => document.removeEventListener('mousedown', handler)
  }, [filterBarFocused])

  // 컬럼 토글 외부 클릭 닫기
  useEffect(() => {
    if (!colToggleOpen) return
    const handler = (e: MouseEvent) => {
      if (colToggleRef.current && !colToggleRef.current.contains(e.target as Node)) {
        setColToggleOpen(false)
      }
    }
    document.addEventListener('mousedown', handler)
    return () => document.removeEventListener('mousedown', handler)
  }, [colToggleOpen])

  // ─── 탭별 기본 필터 + 사용자 필터 적용 ─────────
  const filteredItems = useMemo(() => {
    const allItems = [...workItems, ...getNewV1Items()]
    let items = allItems.map(w => {
      // 1) 사용자 인라인 오버라이드 (반려/취소 등)
      let effectiveStatus = statusOverrides[w.id] ?? w.status
      let cancelReason = w.cancelReason
      let cancelledAt = w.cancelledAt
      // 2) 예외 SQL 정책 가드 — 아직 실행 전 단계(pending/tuning)인 auto 작업은 자동 취소
      if (
        w.selectionSource === 'auto' &&
        (effectiveStatus === 'pending' || effectiveStatus === 'tuning') &&
        isSqlException(w.sqlId)
      ) {
        const ex = findSqlException(w.sqlId)
        effectiveStatus = 'cancelled'
        cancelReason = ex?.reason
          ? `예외 SQL 정책 차단 — ${ex.reason}`
          : '예외 SQL 정책 차단'
        cancelledAt = ex?.registeredAt ?? cancelledAt
      }
      return { ...w, status: effectiveStatus, cancelReason, cancelledAt }
    })

    // 조회조건 필터
    const af = applied
    // 프리셋 필터
    if (af.presets.includes('auto_today')) {
      items = items.filter(w => w.selectionSource === 'auto')
    }
    if (af.presets.includes('tuned_review')) {
      items = items.filter(w => w.status === 'approval_pending')
    }
    if (af.dateStart) {
      const from = new Date(af.dateStart + 'T00:00:00')
      items = items.filter(w => new Date(w.createdAt) >= from)
    }
    if (af.dateEnd) {
      const to = new Date(af.dateEnd + 'T23:59:59')
      items = items.filter(w => new Date(w.createdAt) <= to)
    }
    if (af.instance) items = items.filter(w => w.instanceName === af.instance)
    if (af.sqlId.trim()) {
      const q = af.sqlId.trim().toLowerCase()
      items = items.filter(w => w.sqlId.toLowerCase().includes(q))
    }
    if (af.sqlText.trim()) {
      const q = af.sqlText.trim().toLowerCase()
      items = items.filter(w => w.sqlText.toLowerCase().includes(q))
    }
    if (af.requester.trim()) {
      const q = af.requester.trim().toLowerCase()
      items = items.filter(w => (w.requestedBy ?? '').toLowerCase().includes(q))
    }
    if (af.schemas.length > 0) {
      items = items.filter(w => af.schemas.includes(w.schemaName))
    }
    if (af.modules.length > 0) {
      items = items.filter(w => {
        const m = (w as unknown as { module?: string }).module
        return !m || af.modules.includes(m)
      })
    }
    for (const chip of af.chips) {
      switch (chip.property) {
        case 'status':
          if (chip.value === 'pending') items = items.filter(w => w.status === 'pending' || w.status === 'tuning')
          else items = items.filter(w => w.status === chip.value)
          break
        case 'tuningType':
          items = items.filter(w => w.recommendationTypes?.includes(chip.value as TuningType) ?? false)
          break
        case 'source': items = items.filter(w => w.source === chip.value); break
        case 'selectionSource': items = items.filter(w => w.selectionSource === chip.value); break
        case 'executionResult': items = items.filter(w => w.executionResult === chip.value); break
        case 'integrityResult': items = items.filter(w => w.integrityResult === chip.value); break
      }
    }
    if (af.freeText.trim()) {
      const q = af.freeText.toLowerCase()
      items = items.filter(w =>
        w.sqlId.toLowerCase().includes(q) ||
        w.sqlText.toLowerCase().includes(q) ||
        w.id.toLowerCase().includes(q)
      )
    }
    // 상태 필터 (탭) — scheduled는 기본 작업함에서 제외, 명시적으로 선택한 경우에만 표시
    if (statusFilter === 'all') {
      items = items.filter(w => w.status !== 'scheduled')
    } else {
      items = items.filter(w => w.status === statusFilter)
    }

    // 정렬: 튜닝완료(approval_pending) 맨 위, 대기 건은 수동 큐 순서, 나머지는 최신순
    const qo = getQueueOrder()
    items.sort((a, b) => {
      const so = STATUS_SORT_ORDER[a.status] - STATUS_SORT_ORDER[b.status]
      if (so !== 0) return so
      if (a.status === 'pending' && b.status === 'pending') {
        const aIdx = qo.indexOf(a.id)
        const bIdx = qo.indexOf(b.id)
        if (aIdx !== -1 && bIdx !== -1) return aIdx - bIdx
        if (aIdx !== -1) return -1
        if (bIdx !== -1) return 1
        return (a.queuePosition ?? 999) - (b.queuePosition ?? 999)
      }
      return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
    })

    return items
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [statusOverrides, applied, queueOrderVersion, statusFilter, exceptionTick, aliasTick])

  // ─── 프리셋 건수 + 상태 건수 ──────────────────────
  const { statusCounts, exceptionCancelledCount } = useMemo(() => {
    const allItems = [...workItems, ...getNewV1Items()]
    // 예외 가드 포함한 유효 상태 계산
    const effective = allItems.map(w => {
      let s = statusOverrides[w.id] ?? w.status
      if (
        w.selectionSource === 'auto' &&
        (s === 'pending' || s === 'tuning') &&
        isSqlException(w.sqlId)
      ) {
        s = 'cancelled'
      }
      return { ...w, status: s }
    })
    const counts: Record<string, number> = {}
    for (const w of effective) counts[w.status] = (counts[w.status] || 0) + 1
    const cancelledByException = effective.filter(
      w => w.status === 'cancelled' && w.selectionSource === 'auto' && isSqlException(w.sqlId)
    ).length
    return {
      statusCounts: counts,
      exceptionCancelledCount: cancelledByException,
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [statusOverrides, exceptionTick])


  // ─── 인스턴스 목록 (필터용) ─────────────────────
