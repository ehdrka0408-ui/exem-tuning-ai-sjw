                        <span className={`tabular-nums text-[10px] ${active ? 'text-white/60' : 'text-text-muted'}`}>{s.count}</span>
                      </button>
                    )
                  })}
                </div>
              </div>
            ))}
          </div>
        )
      })()}
      <div className="flex items-center gap-1">
        <div className="ml-auto flex items-center gap-2">
          <div className="inline-flex rounded-md border border-border bg-surface-alt p-0.5">
            <button onClick={() => setViewMode('items')}
              className={`px-3 py-1 text-xs font-medium rounded transition-all duration-[var(--duration-fast)] ${
                viewMode === 'items'
                  ? 'bg-white text-text-primary shadow-sm'
                  : 'text-text-muted hover:text-text-secondary'
              }`}>
              목록
            </button>
            <button onClick={() => setViewMode('batches')}
              className={`px-3 py-1 text-xs font-medium rounded transition-all duration-[var(--duration-fast)] ${
                viewMode === 'batches'
                  ? 'bg-white text-text-primary shadow-sm'
                  : 'text-text-muted hover:text-text-secondary'
              }`}>
              배치
            </button>
          </div>
        </div>
      </div>

      {/* Property Filter Bar */}
      <div className="flex items-start gap-2">
        <div className="relative flex-1 min-w-0" ref={filterBarRef}>
          <div
            className={`flex flex-wrap items-center gap-1.5 rounded-md border bg-white px-3 py-1 min-h-[30px] cursor-text transition-colors ${
              filterBarFocused ? 'border-action ring-1 ring-action/30' : 'border-border'
            }`}
          onClick={() => { filterInputRef.current?.focus(); setFilterBarFocused(true) }}
        >
          <Search size={14} className="text-text-muted shrink-0" />
          {filterChips.length > 0 && <div className="h-4 w-px bg-border shrink-0" />}
          {filterChips.map(chip => (
            <span key={chip.property} className="inline-flex items-center gap-1 rounded-md border border-border px-2 py-0.5 text-[11px] text-text-primary">
              <span className="text-text-muted">{chip.propertyLabel}</span>
              <span className="text-text-muted">=</span>
              <span className="font-medium">{chip.valueLabel}</span>
              <button type="button" onClick={e => { e.stopPropagation(); removeChip(chip.property) }}
                className="ml-0.5 text-text-muted hover:text-text-primary transition-colors">✕</button>
            </span>
          ))}
          {freeText && !filterBarFocused && (
            <span className="inline-flex items-center gap-1 rounded-md border border-border px-2 py-0.5 text-[11px] text-text-primary">
              <span className="font-medium">{freeText}</span>
              <button type="button" onClick={e => { e.stopPropagation(); setFreeText('') }}
                className="ml-0.5 text-text-muted hover:text-text-primary transition-colors">✕</button>
            </span>
          )}
          <input ref={filterInputRef} type="text"
            className="flex-1 min-w-[160px] border-0 outline-none text-xs bg-transparent placeholder:text-text-muted"
            placeholder={filterChips.length > 0 || freeText ? '필터 추가 또는 SQL ID/Text 검색...' : 'SQL ID · SQL Text 검색, 또는 필터 추가...'}
            value={filterBarFocused ? filterQuery : ''}
            onChange={e => setFilterQuery(e.target.value)}
            onFocus={() => { setFilterBarFocused(true); setFilterStep('property') }}
            onKeyDown={e => {
              if (e.key === 'Enter' && filterQuery && filterStep === 'property') {
                setFreeText(filterQuery); setFilterQuery(''); setFilterBarFocused(false)
              }
              if (e.key === 'Backspace' && !filterQuery && filterChips.length > 0) removeChip(filterChips[filterChips.length - 1].property)
              if (e.key === 'Escape') { setFilterBarFocused(false); setFilterStep('property'); setSelectedFilterProp(null); setFilterQuery('') }
            }}
          />
          {(filterChips.length > 0 || freeText) && (
            <button type="button" onClick={e => { e.stopPropagation(); clearAllChips() }}
              className="text-[11px] text-text-muted hover:text-text-primary whitespace-nowrap transition-colors">모두 지우기</button>
          )}
        </div>
        {filterBarFocused && (
          <div className="absolute top-full left-0 right-0 z-50 mt-1 rounded-lg border border-border bg-white shadow-md max-h-64 overflow-y-auto">
            {filterStep === 'property' ? (
              <div className="p-1">
                <p className="px-3 py-1.5 text-[10px] text-text-muted font-medium uppercase tracking-wide">프로퍼티 선택</p>
                {FILTER_PROPERTIES
                  .filter(p => !filterChips.some(c => c.property === p.key))
                  .filter(p => !filterQuery || p.label.includes(filterQuery))
                  .map(prop => (
                    <button key={prop.key} type="button"
                      onClick={() => { setSelectedFilterProp(prop); setFilterStep('value'); setFilterQuery('') }}
                      className="w-full text-left rounded-md px-3 py-2 text-xs text-text-primary hover:bg-surface-muted transition-colors">
                      {prop.label} <span className="text-text-muted ml-1 text-[11px]">({prop.options.length})</span>
                    </button>
                  ))}
                {filterQuery && (
                  <>
                    <div className="border-t border-border my-1" />
                    <button type="button"
                      onClick={() => { setFreeText(filterQuery); setFilterQuery(''); setFilterBarFocused(false) }}
                      className="w-full text-left rounded-md px-3 py-2 text-xs text-text-secondary hover:bg-surface-muted transition-colors">
                      <span className="text-text-muted">전체 검색:</span> &quot;{filterQuery}&quot;
                    </button>
                  </>
                )}
              </div>
            ) : selectedFilterProp ? (
              <div className="p-1">
                <div className="flex items-center gap-2 px-3 py-1.5">
                  <button type="button" onClick={() => { setFilterStep('property'); setSelectedFilterProp(null); setFilterQuery('') }}
                    className="text-text-muted hover:text-text-primary text-[11px] transition-colors">← 뒤로</button>
                  <span className="text-[10px] text-text-muted font-medium uppercase tracking-wide">{selectedFilterProp.label} =</span>
                </div>
                {selectedFilterProp.options
                  .filter(o => !filterQuery || o.label.includes(filterQuery))
                  .map(opt => (
                    <button key={opt.value} type="button" onClick={() => addChip(selectedFilterProp, opt.value, opt.label)}
                      className="w-full text-left rounded-md px-3 py-2 text-xs text-text-primary hover:bg-surface-muted transition-colors">{opt.label}</button>
                  ))}
              </div>
            ) : null}
          </div>
        )}
        </div>
      </div>

      {/* 자동 제외 Meta (예외/중복) + 직접 튜닝요청 */}
      <div className="flex items-center gap-3 text-xs">
        {exceptionCancelledCount > 0 && (
          <button
            onClick={() => setStatusFilter('cancelled')}
            className="inline-flex items-center gap-1.5 rounded-md px-2 py-0.5 text-text-muted hover:bg-surface-muted hover:text-text-secondary transition-colors self-start"
            title="취소됨 상태로 필터링"
          >
            <Ban className="h-3 w-3" />
            예외 정책으로 자동 작업 <span className="font-medium text-text-secondary">{exceptionCancelledCount}건</span> 취소됨
            <span className="text-[10px] text-text-muted">→ 보기</span>
          </button>
        )}
        <div className="ml-auto flex items-center gap-2">
          <button
            onClick={() => navigate('/canvas')}
            className="inline-flex items-center gap-2 shrink-0 px-3 py-1.5 rounded-lg text-[13px] font-medium bg-code-bg text-action hover:bg-[#D2E3FC] hover:text-action-hover active:scale-[0.98] transition-colors"
            title="직접 SQL 입력하여 튜닝 요청"
          >
            <SquarePen size={15} />
            사용자 SQL입력
          </button>
          <div className="relative" ref={colToggleRef}>
            <button
              onClick={() => setColToggleOpen(p => !p)}
              className={`p-1.5 rounded-md border transition-colors ${colToggleOpen ? 'border-action bg-surface-muted text-text-primary' : 'border-border text-text-muted hover:text-text-secondary hover:bg-surface-muted'}`}
              title="컬럼 표시 설정"
            >
              <SlidersHorizontal size={14} />
            </button>
            {colToggleOpen && (
              <div className="absolute right-0 top-full mt-1 z-20 w-44 rounded-lg border border-border bg-white shadow-lg py-1">
                <p className="px-3 py-1.5 text-[10px] font-medium text-text-muted uppercase tracking-wide">컬럼 표시</p>
                <div className="max-h-[280px] overflow-y-auto">
                {TOGGLE_COLUMNS.map(key => (
                  <label key={key} className="flex items-center gap-2 px-3 py-1.5 text-xs text-text-primary hover:bg-surface-muted cursor-pointer transition-colors">
                    <input
                      type="checkbox"
                      className="h-3.5 w-3.5 rounded border-border"
                      checked={!hiddenCols.has(key)}
                      onChange={() => setHiddenCols(prev => {
                        const next = new Set(prev)
                        if (next.has(key)) next.delete(key); else next.add(key)
                        return next
                      })}
                    />
                    {COLUMN_LABELS[key] || key}
                  </label>
                ))}
                </div>
                <div className="border-t border-border mt-1 pt-1 px-3 pb-1.5">
                  <button onClick={() => setHiddenCols(new Set(DEFAULT_HIDDEN))} className="text-[11px] text-text-muted hover:text-text-primary transition-colors">초기화</button>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* 목록 보기: DataTable */}
      {viewMode === 'items' && (
        <div className="flex-1 min-h-0 flex flex-col">
          <DataTable
            columns={visibleColumns}
            data={sortedItems}
            rowKey="id"
            onRowClick={(row, ri, e) => navigateToDetail(row, ri, e)}
            onColumnsChange={(cols) => setColumnOrder(cols as ColumnDef<WorkItem>[])}
            rowClassName={(row) => row.id === highlightId ? 'highlight-new-item' : ''}
            sort={sortState}
            onSortChange={setSortState}
            virtualScroll
            className="flex-1 min-h-0"
          />
        </div>
      )}

      {/* 배치 보기 */}
      {viewMode === 'batches' && (
        <DataTable
          columns={batchColumns}
          data={batchGroups}
          rowKey={(row) => row.batchId}
          hideHeader
          fluid
          onRowClick={(row) => navigateToBatchItems(row)}
          renderExpandedRow={(batch) => {
            if (expandedBatchId !== batch.batchId) return null
            // 배치 헤더에 이미 노출된 정보(요청일시·인스턴스)와
            // 체크박스는 펼침에서 제외해 가로 스크롤 방지
            const REDUNDANT_IN_GROUP = new Set(['createdAt', 'instanceName', 'batchMemo', 'groupLabel', '_group'])
            const expandedCols = visibleColumns.filter(c => !REDUNDANT_IN_GROUP.has(c.key))
            return (
              <div className="border-t border-surface-muted bg-surface-alt border-l-2 border-l-code pl-6 pr-2 py-2">
                <DataTable
                  columns={expandedCols}
                  data={batch.items}
                  rowKey={(row) => row.id}
                  borderless
                  fluid
                  onRowClick={(row, ri, e) => navigateToDetail(row, ri, e)}
                  rowClassName={() => 'group'}
                />
              </div>
            )
          }}
        />
      )}

      {/* 일괄 처리 플로팅 바 */}
      {selectedTunedCount > 0 && (
        <div className="fixed bottom-6 left-1/2 -translate-x-1/2 z-40 bg-white border border-border rounded-lg shadow-lg px-6 py-3 flex items-center gap-4 animate-[slideUp_150ms_var(--ease-out)]">
          <span className="text-sm font-medium text-text-primary">{selectedTunedCount}건 선택됨</span>
          <Button size="sm" onClick={handleBulkVerify}>
            <CheckCircle2 size={13} className="mr-1" /> 일괄 확인
          </Button>
          <button
            onClick={() => setSelectedIds(new Set())}
            className="text-xs text-text-secondary hover:text-text-primary transition-colors"
          >
            선택 해제
          </button>
        </div>
      )}

      </>}{/* end of LIST 뷰 */}

      {/* ─── 모달 ─── */}
      {confirmAction && (
        <ConfirmDialog
          open
          title={confirmAction.title}
          message={confirmAction.message}
          variant={confirmAction.variant}
          confirmLabel="확인"
          cancelLabel="취소"
          onConfirm={confirmAction.onConfirm}
          onCancel={() => setConfirmAction(null)}
        >
          {confirmAction.item && (() => {
            const it = confirmAction.item!
            const eRate = calcRate(it.originalElapsed, it.tunedElapsed)
            const bRate = calcRate(it.originalBuffers, it.tunedBuffers)
            const execLabel = it.executionResult === 'completed' ? '실측' : it.executionResult === 'timeout' ? 'T/O' : '예상'
            const intLabel = it.integrityResult === 'match' ? '일치' : it.integrityResult === 'mismatch' ? '불일치' : '미확인'
            return (
              <div className="mt-3 space-y-2.5">
                <div className="rounded-lg border border-border bg-surface-alt px-3 py-2">
                  <p className="text-[11px] text-text-muted mb-1">SQL ID</p>
                  <p className="font-mono text-xs font-semibold text-text-primary">{it.sqlId}</p>
                </div>
                <div className="rounded-lg border border-border bg-surface-alt px-3 py-2">
                  <p className="text-[11px] text-text-muted mb-1">SQL Text</p>
                  <p className="font-mono text-[11px] text-text-primary leading-relaxed line-clamp-3">{it.sqlText}</p>
                </div>
                <div className="grid grid-cols-2 gap-2">
                  <div className="rounded-lg border border-border bg-white px-3 py-2">
                    <p className="text-[11px] text-text-muted">Elapsed</p>
                    <p className="text-xs font-mono text-text-primary mt-0.5">
                      {fmtElapsed(it.originalElapsed)} → {fmtElapsed(it.tunedElapsed)}
                      {eRate != null && eRate !== 0 && (
                        <span className={`ml-1 font-medium ${eRate > 0 ? 'text-success' : 'text-danger'}`}>
                          {eRate > 0 ? '▼' : '▲'}{Math.abs(eRate)}%
                        </span>
                      )}
                    </p>
                  </div>
                  <div className="rounded-lg border border-border bg-white px-3 py-2">
                    <p className="text-[11px] text-text-muted">Buffers</p>
                    <p className="text-xs font-mono text-text-primary mt-0.5">
                      {fmtBuffers(it.originalBuffers)} → {fmtBuffers(it.tunedBuffers)}
                      {bRate != null && bRate !== 0 && (
                        <span className={`ml-1 font-medium ${bRate > 0 ? 'text-success' : 'text-danger'}`}>
                          {bRate > 0 ? '▼' : '▲'}{Math.abs(bRate)}%
                        </span>
                      )}
                    </p>
                  </div>
                </div>
                <div className="flex gap-2">
                  <div className="flex-1 rounded-lg border border-border bg-white px-3 py-2">
                    <p className="text-[11px] text-text-muted">검증방식</p>
                    <p className="text-xs font-medium text-text-primary mt-0.5">{execLabel}</p>
                  </div>
                  <div className="flex-1 rounded-lg border border-border bg-white px-3 py-2">
                    <p className="text-[11px] text-text-muted">결과일치</p>
                    <p className={`text-xs font-medium mt-0.5 ${it.integrityResult === 'match' ? 'text-success' : it.integrityResult === 'mismatch' ? 'text-danger' : 'text-warning'}`}>{intLabel}</p>
                  </div>
                  <div className="flex-1 rounded-lg border border-border bg-white px-3 py-2">
                    <p className="text-[11px] text-text-muted">인스턴스</p>
                    <p className="text-xs text-text-primary mt-0.5">{it.instanceName}</p>
                  </div>
                </div>
                <p className="text-[11px] text-text-muted">확인 시 반영대기 상태로 전환됩니다.</p>
              </div>
            )
          })()}
        </ConfirmDialog>
      )}

      {/* 슬라이드 패널 — peek 전용 (좁은 모드만, maximize → workspace 전환) */}
      <SlidePanel
        open={!!panelItem && pageView === 'list'}
        onClose={() => setPanelItem(null)}
        title={panelItem?.sqlId || ''}
        defaultWidthRatio={0.4}
        noBackdrop
        controlledMode={'slide' as PanelMode}
        onModeChange={(mode) => {
          if (mode === 'maximized' && panelItem) {
            enterWorkspace(panelItem)
            return
          }
          setPanelMode(mode)
        }}
        onWidthChange={(_w, m) => {
          // maximize로 전환되면 workspace로 이동
          if (m === 'maximized' && panelItem) {
            enterWorkspace(panelItem)
            return
          }
          if (m !== panelMode) setPanelMode(m)
        }}
        onOpenNewTab={panelItem ? () => window.open(`/work/${panelItem.id}?popup=true`, '_blank') : undefined}
        contentClassName={panelItem && getStatus(panelItem) === 'approval_pending' ? 'flex-1 overflow-y-auto px-6 pt-6' : undefined}
        headerContent={panelItem ? (
          <div className="flex items-center gap-3 min-w-0">
            <span className="font-mono text-sm font-semibold text-text-primary shrink-0">{panelItem.sqlId}</span>
            <div className="w-px h-4 bg-surface-muted shrink-0" />
            <StatusIndicator status={panelItem.status} />
          </div>
        ) : undefined}
      >
        {panelItem && (
          <WorkDetailPanel
            key={panelItem.id}
            item={panelItem}
            panelMode={panelMode}
            onOpenWorkbench={() => enterWorkspace(panelItem)}
            onVerify={() => {
              setStatusOverrides(prev => ({ ...prev, [panelItem.id]: 'apply_pending' }))
            }}
            onReject={(onConfirmed) => {
              setRejectTarget(panelItem)
              rejectConfirmedRef.current = onConfirmed || null
            }}
            onRetune={() => {
              setStatusOverrides(prev => ({ ...prev, [panelItem.id]: 'pending' }))
              showToast(`${panelItem.sqlId} — 재튜닝 요청. 대기 큐에 등록되었습니다.`)
            }}
            onCancel={() => {
              setConfirmAction({
                title: '튜닝 중단', variant: 'danger',
                message: `${panelItem.sqlId}\n진행 중인 튜닝을 중단하시겠습니까?`,
                onConfirm: () => {
                  setStatusOverrides(prev => ({ ...prev, [panelItem.id]: 'cancelled' }))
                  setPanelItem(null)
                  setConfirmAction(null)
                  showToast(`${panelItem.sqlId} — 튜닝이 중단되었습니다.`)
                },
              })
            }}
          />
        )}
      </SlidePanel>

      {/* 반려 사유 모달 */}
      {rejectTarget && (
        <>
          <div className="fixed inset-0 z-50 bg-black/30" onClick={() => setRejectTarget(null)} />
          <div className="fixed inset-0 z-50 flex items-center justify-center p-4">
            <div className="bg-white rounded-lg shadow-lg border border-border w-[420px] overflow-hidden" onClick={e => e.stopPropagation()}>
              <div className="px-5 py-4 border-b border-border flex items-center justify-between">
                <h3 className="text-sm font-semibold text-text-primary">반려</h3>
                <button onClick={() => setRejectTarget(null)} className="text-text-muted hover:text-text-secondary"><X size={16} /></button>
              </div>
              <div className="px-5 py-4">
                <div className="text-xs text-text-secondary mb-2">{rejectTarget.sqlId}</div>
                <label className="block text-xs font-medium text-text-primary mb-1">반려 사유</label>
                <textarea
                  className="w-full border border-border rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-danger/30 resize-none"
                  rows={3}
                  placeholder="반려 사유를 입력하세요..."
                  value={rejectReason}
                  onChange={e => setRejectReason(e.target.value)}
                />
              </div>
              <div className="px-5 py-3 border-t border-border flex justify-end gap-2">
                <Button size="sm" variant="secondary" onClick={() => setRejectTarget(null)}>취소</Button>
                <Button size="sm" variant="danger" onClick={confirmReject} disabled={!rejectReason.trim()}>반려</Button>
              </div>
            </div>
          </div>
        </>
      )}

      {/* SQL 전체보기 — ComparePanel 재활용 */}
      {sqlPreview && (
        <ComparePanel
          onClose={() => setSqlPreview(null)}
          mode={{ type: 'single', target: 'sql-before' } as ComparePanelMode}
          data={{ sqlBefore: sqlPreview.sqlText || '', sqlAfter: '', planBefore: '', planAfter: '' } as ComparePanelData}
        />
      )}

      {/* 직접 튜닝요청 슬라이드 패널 */}
      <SlidePanel
        open={directInputOpen}
        onClose={() => setDirectInputOpen(false)}
        title="직접 튜닝요청"
        defaultWidthRatio={0.5}
      >
        <div className="p-6">
          <DirectInputForm
            onCreated={(id) => {
              setDirectInputOpen(false)
              setHighlightId(id)
              setToast('직접 튜닝요청이 작업함에 추가되었습니다')
              setTimeout(() => setToast(null), 4500)
            }}
            onNavigateToExisting={(id) => {
              setDirectInputOpen(false)
              const found = [...workItems, ...getNewV1Items()].find(w => w.id === id)
              if (found) setPanelItem(found)
            }}
          />
        </div>
      </SlidePanel>

      {/* Toast */}
      {toast && (
        <div className="fixed top-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 rounded-lg bg-white border border-border px-5 py-3.5 text-sm text-text-primary shadow-xl"
          style={{ animation: 'toastDrop 200ms var(--ease-out)' }}>
          <CheckCircle2 className="h-5 w-5 text-success shrink-0" />
          <span className="font-medium">{toast}</span>
        </div>
      )}
    </div>
  )
}
