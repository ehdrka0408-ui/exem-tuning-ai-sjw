        if (st === 'pending') return (
          <div className="flex items-center justify-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-100" onClick={e => e.stopPropagation()}>
            <button onClick={() => handlePrioritize(row)}
              className="px-2 py-0.5 text-[11px] font-medium text-text-primary border border-border hover:bg-surface-muted rounded transition-colors whitespace-nowrap">
              우선처리
            </button>
            <button onClick={() => handleCancel(row)}
              className="px-2 py-0.5 text-[11px] font-medium text-text-muted hover:text-danger hover:bg-danger-bg rounded transition-colors">
              취소
            </button>
          </div>
        )
        if (st === 'tuning') return (
          <div className="flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-100" onClick={e => e.stopPropagation()}>
            <button onClick={() => handleCancel(row)}
              className="px-2 py-0.5 text-[11px] font-medium text-text-muted hover:text-danger hover:bg-danger-bg rounded transition-colors">
              취소
            </button>
          </div>
        )
        return <span className="text-xs text-text-muted/40">—</span>
      },
    },
    {
      key: '_workbench', header: '', width: 36, minWidth: 36, resizable: false, draggable: false, sortable: false,
      render: (_v, row) => (
        <div className="flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-100" onClick={e => e.stopPropagation()}>
          <button
            onClick={() => enterWorkspace(row)}
            className="p-1 rounded text-text-muted hover:text-code hover:bg-code-bg transition-colors"
            title="워크스페이스에서 상세 검토"
          >
            <Maximize2 size={13} />
          </button>
        </div>
      ),
    },
  ], [selectedIds, toggleSelect, handleVerify, handleRetune, handleCancel, handlePrioritize, getStatus, ImprovementPct, tuningTick])

  // 컬럼 순서 반영 + 숨김 필터
  const orderedColumns = useMemo(() => {
    if (!columnOrder) return columns
    // columnOrder 기준, 새로 추가된 컬럼은 뒤에 붙임
    const keySet = new Set(columnOrder.map(c => c.key))
    const reordered = columnOrder.map(oc => columns.find(c => c.key === oc.key)!).filter(Boolean)
    columns.forEach(c => { if (!keySet.has(c.key)) reordered.push(c) })
    return reordered
  }, [columns, columnOrder])

  const visibleColumns = useMemo(() => orderedColumns.filter(c => !hiddenCols.has(c.key)), [orderedColumns, hiddenCols])

  // 정렬 적용
  const sortedItems = useMemo(() => {
    if (!sortState.key || !sortState.direction) return filteredItems
    const key = sortState.key
    const dir = sortState.direction === 'asc' ? 1 : -1
    // 파생 키 (2중 헤더 개선율) 매핑
    const deriveVal = (row: WorkItem): number | string | null | undefined => {
      if (key === '_elapsed_rate') return calcRate(row.originalElapsed, row.tunedElapsed)
      if (key === '_buffers_rate') return calcRate(row.originalBuffers, row.tunedBuffers)
      return (row as unknown as Record<string, unknown>)[key] as number | string | null | undefined
    }
    return [...filteredItems].sort((a, b) => {
      const av = deriveVal(a)
      const bv = deriveVal(b)
      if (av == null && bv == null) return 0
      if (av == null) return 1
      if (bv == null) return -1
      if (typeof av === 'number' && typeof bv === 'number') return (av - bv) * dir
      return String(av).localeCompare(String(bv)) * dir
    })
  }, [filteredItems, sortState])

  // 토글 가능 컬럼 (체크박스/액션/필수 컬럼 제외)
  // 필수(required) 컬럼: sqlId, sqlText, status, recommendationTypes — 사용자가 숨길 수 없음
  const REQUIRED_COLUMNS = new Set(['sqlId', 'sqlText', 'status', 'recommendationTypes'])
  const TOGGLE_COLUMNS = useMemo(() =>
    columns
      .filter(c => c.key !== '_select' && c.key !== '_actions' && c.key !== '_workbench' && !REQUIRED_COLUMNS.has(c.key))
      .map(c => c.key),
    [columns]
  )
  const COLUMN_LABELS: Record<string, string> = {
    createdAt: '요청일시', alias: '별칭', sqlId: 'SQL ID', sqlText: 'SQL Text',
    instanceName: '인스턴스', schemaName: '스키마', module: '모듈',
    selectionSource: '소스', _selectionReason: '선정근거',
    estimatedDailyExec: '수행횟수', requestedBy: '요청자', status: '상태', recommendationTypes: '튜닝 내용',
    _elapsed: 'Elapsed', _buffers: 'Buffers',
    executionResult: '실측/예상', integrityResult: '결과일치',
  }

  // ─── 배치 보기: 작업 단위로 그룹핑 (job-centric) ─────────────────
  interface BatchGroup {
    batchId: string
    batchMemo: string
    items: WorkItem[]
    source: WorkItem['selectionSource']
    instanceLabel: string
    requestedBy: string
    startTime: Date              // 요청시간 (min createdAt)
    tuningStartTime: Date | null // 시작시간 (earliest non-pending transition)
    endTime: Date                // 종료시간 (max updatedAt)
    isRunning: boolean
    durationMs: number
    total: number
    pendingCnt: number    // pending (튜닝대기)
    tuningCnt: number     // tuning (튜닝중)
    tuningDone: number    // approval_pending + apply_pending + applied (튜닝완료)
    failed: number        // rejected/cancelled (실패)
  }

  const batchGroupsAll = useMemo<BatchGroup[]>(() => {
    const groups: Record<string, WorkItem[]> = {}
    filteredItems.forEach(w => {
      if (!groups[w.batchId]) groups[w.batchId] = []
      groups[w.batchId].push(w)
    })
    return Object.entries(groups).map(([batchId, items]) => {
      const first = items[0]
      const instances = new Set(items.map(i => i.instanceName))
      const instanceLabel = instances.size > 1
        ? `${[...instances][0]} 외 ${instances.size - 1}`
        : [...instances][0]
      const createdTimes = items.map(i => new Date(i.createdAt).getTime())
      const updatedTimes = items.map(i => new Date(i.updatedAt).getTime())
      const startTime = new Date(Math.min(...createdTimes))
      const endTime = new Date(Math.max(...updatedTimes))
      const nonPendingTimes = items.filter(i => i.status !== 'pending').map(i => new Date(i.updatedAt).getTime())
      const tuningStartTime = nonPendingTimes.length > 0 ? new Date(Math.min(...nonPendingTimes)) : null
      const isRunning = items.some(i => i.status === 'pending' || i.status === 'tuning')
      let pendingCnt = 0, tuningCnt = 0, tuningDone = 0, failed = 0
      items.forEach(i => {
        if (i.status === 'pending') pendingCnt++
        else if (i.status === 'tuning') tuningCnt++
        else if (i.status === 'approval_pending' || i.status === 'apply_pending' || i.status === 'applied') tuningDone++
        else if (i.status === 'rejected' || i.status === 'cancelled' || i.status === 'no_improve') failed++
      })
      return {
        batchId,
        batchMemo: first.batchMemo || batchId,
        items,
        source: first.selectionSource,
        instanceLabel,
        requestedBy: first.requestedBy || '',
        startTime,
        tuningStartTime,
        endTime,
        isRunning,
        durationMs: endTime.getTime() - startTime.getTime(),
        total: items.length,
        pendingCnt,
        tuningCnt,
        tuningDone,
        failed,
      }
    })
  }, [filteredItems])

  // applied(조회 시 커밋된 범위) 기준으로 필터 + 시작시각 내림차순 정렬 — Deferred 일관성
  const batchGroups = useMemo<BatchGroup[]>(() => {
    const s = applied.dateStart ? new Date(applied.dateStart + 'T00:00:00').getTime() : -Infinity
    const e = applied.dateEnd ? new Date(applied.dateEnd + 'T23:59:59').getTime() : Infinity
    return batchGroupsAll
      .filter(g => {
        const t = g.startTime.getTime()
        return t >= s && t <= e
      })
      .sort((a, b) => b.startTime.getTime() - a.startTime.getTime())
  }, [batchGroupsAll, applied.dateStart, applied.dateEnd])

  // 작업명: batchMemo가 있으면 사용, 없으면 batchId
  const jobTitle = (g: BatchGroup) => g.batchMemo

  // 시각 포맷: MM/DD HH:mm
  const fmtJobTime = (d: Date) =>
    `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`

  // 시각 포맷 (시분만): HH:mm
  const fmtTimeOnly = (d: Date) =>
    `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`

  // 소요 시간: 1h15m / 42m / 12s
  const fmtDuration = (ms: number) => {
    const sec = Math.max(0, Math.round(ms / 1000))
    const h = Math.floor(sec / 3600)
    const m = Math.floor((sec % 3600) / 60)
    const s = sec % 60
    if (h > 0) return `${h}h${m}m`
    if (m > 0) return `${m}m`
    return `${s}s`
  }

  const batchColumns = useMemo((): ColumnDef<BatchGroup>[] => [
    {
      key: '_job', header: '', width: 1200, minWidth: 600, resizable: false, draggable: false,
      render: (_v, row) => {
        const expanded = expandedBatchId === row.batchId
        const t = row.total || 1
        const completedCnt = row.tuningDone + row.failed
        const completionPct = (completedCnt / t) * 100
        return (
          <div className="flex items-start gap-3 py-1.5">
            {/* 토글 chevron */}
            <ChevronDown
              size={14}
              className={`shrink-0 text-text-muted mt-0.5 transition-transform duration-[var(--duration-fast)] ${expanded ? 'rotate-0' : '-rotate-90'}`}
            />

            {/* 좌측: 작업명 + 시간 메타 (2줄) */}
            <div className="min-w-0 flex-1">
              <div className="flex items-center gap-2">
                <span className="text-[13px] font-semibold text-text-primary truncate">
                  {jobTitle(row)}
                </span>
                {row.isRunning && (
                  <span className="shrink-0 inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-action/10 text-action">
                    <span className="w-1.5 h-1.5 rounded-full bg-action animate-pulse" />
                    진행중
                  </span>
                )}
              </div>
              <div className="flex items-center gap-1.5 mt-0.5 text-[11px] text-text-muted font-mono tabular-nums whitespace-nowrap">
                <span>{row.instanceLabel}</span>
                <span className="opacity-40">·</span>
                <span>요청 {fmtJobTime(row.startTime)}</span>
                {row.tuningStartTime && (
                  <>
                    <span className="opacity-40">·</span>
                    <span>시작 {fmtTimeOnly(row.tuningStartTime)}</span>
                  </>
                )}
                {!row.isRunning && (
                  <>
                    <span className="opacity-40">·</span>
                    <span>종료 {fmtTimeOnly(row.endTime)}</span>
                    <span className="opacity-40">·</span>
                    <span>소요 {fmtDuration(row.durationMs)}</span>
                  </>
                )}
              </div>
            </div>

            {/* 우측: 게이지 + 라벨 건수 (2줄) */}
            <div className="shrink-0 flex flex-col items-end gap-1">
              {/* 진행률 게이지 — 목록뷰 동일 스타일 */}
              <div className="flex items-center gap-1.5 w-[180px]">
                <CostSweepHero size="xs" color={row.isRunning ? 'blue' : 'green'} animated={row.isRunning} className="shrink-0" />
                <div className="relative h-2 flex-1 bg-surface-muted rounded-full overflow-hidden">
                  <div
                    className={`absolute inset-y-0 left-0 rounded-full transition-[width] duration-500 ease-out overflow-hidden ${row.isRunning ? 'bg-action' : 'bg-success'}`}
                    style={{ width: `${completionPct}%` }}
                  >
                    {row.isRunning && <div className="absolute inset-0 tuning-gauge-shimmer" />}
                  </div>
                </div>
                <span className="text-[10px] font-mono tabular-nums text-text-secondary shrink-0 w-[28px] text-right">
                  {row.isRunning ? `${Math.round(completionPct)}%` : `${row.total}건`}
                </span>
              </div>
              {/* 상태별 건수 — 라벨 + 숫자 */}
              <div className="flex items-center gap-2.5 text-[11px] tabular-nums">
                <span className={`flex items-center gap-0.5 ${row.pendingCnt > 0 ? 'text-text-secondary' : 'text-text-muted/40'}`}>
                  <span className="w-1.5 h-1.5 rounded-full bg-text-muted/40 shrink-0" />
                  대기 {row.pendingCnt}
                </span>
                <span className={`flex items-center gap-0.5 ${row.tuningCnt > 0 ? 'text-action' : 'text-text-muted/40'}`}>
                  <span className="w-1.5 h-1.5 rounded-full bg-action shrink-0" />
                  튜닝 {row.tuningCnt}
                </span>
                <span className={`flex items-center gap-0.5 ${row.tuningDone > 0 ? 'text-warning' : 'text-text-muted/40'}`}>
                  <span className="w-1.5 h-1.5 rounded-full bg-warning shrink-0" />
                  완료 {row.tuningDone}
                </span>
                <span className={`flex items-center gap-0.5 ${row.failed > 0 ? 'text-danger' : 'text-text-muted/40'}`}>
                  <span className="w-1.5 h-1.5 rounded-full bg-danger shrink-0" />
                  실패 {row.failed}
                </span>
              </div>
            </div>
          </div>
        )
      },
    },
  ], [expandedBatchId])

  // ─── 네비게이션 ─────────────────────────────────
  const navigateToDetail = useCallback((item: WorkItem, _ri: number, e?: React.MouseEvent) => {
    if (e && (e.ctrlKey || e.metaKey)) {
      e.preventDefault()
      window.open(`/work?detail=${item.id}`, '_blank')
      return
    }
    // 더블클릭 → 워크스페이스 뷰 전환 (detail.type으로 판별)
    if (e && e.detail === 2) {
