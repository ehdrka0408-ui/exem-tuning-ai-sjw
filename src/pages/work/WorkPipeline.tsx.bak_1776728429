      {/* ═══ LIST 뷰 — 기존 필터 + 테이블 + peek 패널 ═══ */}
      {pageView === 'list' && <>
      {/* 조회조건 바 (접기/펼치기) */}
      {(() => {
        const arrayEq = (a: string[], b: string[]) => a.length === b.length && a.every((v, i) => v === b[i])
        const isDirty =
          fmtIsoDate(startTime) !== applied.dateStart ||
          fmtIsoDate(endTime) !== applied.dateEnd ||
          selectedInstance !== applied.instance ||
          sqlIdQuery !== applied.sqlId ||
          sqlTextQuery !== applied.sqlText ||
          requesterQuery !== applied.requester ||
          !arrayEq(schemas, applied.schemas) ||
          !arrayEq(modules, applied.modules)

        return (
        <div className="flex items-center gap-2 rounded-lg bg-surface-alt px-3 py-1.5 flex-wrap">
          <select value={selectedInstance} onChange={e => setSelectedInstance(e.target.value)}
            className="h-7 text-xs border border-border rounded-md px-2 focus:outline-none focus:ring-1 focus:ring-action/30 bg-white">
            <option value="">전체 인스턴스</option>
            {instances.map(inst => <option key={inst} value={inst}>{inst}</option>)}
          </select>
          <TimeRangePicker startTime={startTime} endTime={endTime} onChange={handleTimeRangeChange} />
          <MultiSelect label="스키마" options={SCHEMAS} selected={schemas} onChange={setSchemas} />
          <MultiSelect label="모듈" options={MODULES} selected={modules} onChange={setModules} />
          <input
            type="text"
            value={sqlIdQuery}
            onChange={e => setSqlIdQuery(e.target.value)}
            onKeyDown={e => { if (e.key === 'Enter') handleQuery() }}
            placeholder="SQL ID"
            className="h-7 text-xs font-mono border border-border rounded-md px-2 w-[120px] focus:outline-none focus:ring-1 focus:ring-action/30 bg-white placeholder:text-text-muted"
          />
          <input
            type="text"
            value={sqlTextQuery}
            onChange={e => setSqlTextQuery(e.target.value)}
            onKeyDown={e => { if (e.key === 'Enter') handleQuery() }}
            placeholder="SQL Text"
            className="h-7 text-xs font-mono border border-border rounded-md px-2 flex-1 min-w-[120px] focus:outline-none focus:ring-1 focus:ring-action/30 bg-white placeholder:text-text-muted"
          />
          <input
            type="text"
            value={requesterQuery}
            onChange={e => setRequesterQuery(e.target.value)}
            onKeyDown={e => { if (e.key === 'Enter') handleQuery() }}
            placeholder="요청자"
            className="h-7 text-xs border border-border rounded-md px-2 w-[100px] focus:outline-none focus:ring-1 focus:ring-action/30 bg-white placeholder:text-text-muted"
          />
          <div className="ml-auto">
            <button
              onClick={handleQuery}
              className={`shrink-0 h-7 rounded-md px-4 text-xs font-semibold text-white transition-colors inline-flex items-center justify-center ${
                isDirty ? 'bg-action hover:bg-action-hover ring-2 ring-info/40' : 'bg-action hover:bg-action-hover'
              }`}
            >
              조회{isDirty ? ' •' : ''}
            </button>
          </div>
        </div>
        )
      })()}

      {/* 상태 필터 파이프라인 + 뷰 토글 */}
      {(() => {
        const cnt = (k: string) => (statusCounts as Record<string,number>)[k] || 0
        const totalCount = Object.entries(statusCounts).reduce((a, [k, v]) => k === 'scheduled' ? a : a + v, 0)

        type BtnDef = { key: WorkItem['status'] | 'all' | 'applied_all'; label: string; dot: string; count: number }
        const groups: BtnDef[][] = [
          [{ key: 'all', label: '전체', dot: '', count: totalCount }],
          [{ key: 'pending', label: '튜닝대기', dot: STATUS_DOT_COLOR.pending, count: cnt('pending') }],
          [
            { key: 'tuning', label: '튜닝중', dot: STATUS_DOT_COLOR.tuning, count: cnt('tuning') },
            { key: 'failed', label: '실패', dot: STATUS_DOT_COLOR.failed, count: cnt('failed') },
            { key: 'cancelled', label: '취소', dot: STATUS_DOT_COLOR.cancelled, count: cnt('cancelled') },
          ],
          [
            { key: 'approval_pending', label: '튜닝완료', dot: STATUS_DOT_COLOR.approval_pending, count: cnt('approval_pending') },
            { key: 'no_improve', label: '개선없음', dot: STATUS_DOT_COLOR.no_improve, count: cnt('no_improve') },
          ],
          [
            { key: 'apply_pending', label: '반영대기', dot: STATUS_DOT_COLOR.apply_pending, count: cnt('apply_pending') },
            { key: 'rejected', label: '반려', dot: STATUS_DOT_COLOR.rejected, count: cnt('rejected') },
          ],
          [{ key: 'applied_all', label: '반영완료', dot: STATUS_DOT_COLOR.applied, count: cnt('applied') + cnt('fulfilled') }],
        ]

        const btnCls = (active: boolean, isFirst: boolean, isLast: boolean) =>
          `h-8 px-3 text-[11px] font-semibold transition-all flex items-center gap-1.5 border ` +
          (isFirst && isLast ? 'rounded-lg ' : isFirst ? 'rounded-l-lg border-r-0 ' : isLast ? 'rounded-r-lg ' : 'border-r-0 ') +
          (active
            ? 'bg-action text-white border-action z-10 relative'
            : 'bg-surface-alt text-text-secondary border-border hover:bg-surface-muted')

        return (
          <div className="flex items-center gap-1.5">
            {groups.map((group, gi) => (
              <div key={gi} className="flex items-center">
                {gi === 1 && <div className="w-3" />}
                {gi > 1 && (
                  <svg className="shrink-0 text-border mr-1.5" width="12" height="12" viewBox="0 0 16 16" fill="none">
                    <path d="M6 3l5 5-5 5" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
                  </svg>
                )}
                <div className="inline-flex">
                  {group.map((s, bi) => {
                    const filterKey = s.key === 'applied_all' ? 'applied' as const : s.key === 'all' ? 'all' : s.key as WorkItem['status']
                    const active = statusFilter === filterKey
                    return (
                      <button key={s.key} onClick={() => setStatusFilter(filterKey)}
                        className={btnCls(active, bi === 0, bi === group.length - 1)}>
                        {s.dot && <span className={`size-1.5 rounded-full shrink-0 ${active ? 'bg-white/70' : s.dot}`} />}
